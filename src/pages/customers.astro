---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Customers" activePage="customers">

  <!-- Action bar -->
  <div class="flex flex-wrap items-center gap-3 mb-6">
    <!-- Upload CSV -->
    <label for="csv-upload"
           class="inline-flex items-center gap-2 cursor-pointer bg-orange-500 hover:bg-orange-600
                  text-white font-medium text-sm px-4 py-2.5 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
      </svg>
      Import CSV
    </label>
    <input type="file" id="csv-upload" accept=".csv" class="hidden" />

    <!-- Add Customer -->
    <button onclick="openAddModal()"
            class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600
                   text-white font-medium text-sm px-4 py-2.5 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Add Customer
    </button>

    <!-- Export CSV -->
    <button onclick="exportCustomers()"
            class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 border border-gray-300
                   text-gray-700 font-medium text-sm px-4 py-2.5 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      Export CSV
    </button>

    <!-- Clear all -->
    <button onclick="clearAllCustomers()"
            class="inline-flex items-center gap-2 bg-white hover:bg-red-50 border border-gray-300
                   hover:border-red-300 text-gray-500 hover:text-red-600 font-medium text-sm
                   px-4 py-2.5 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
      Clear All
    </button>

    <span id="customer-count" class="ml-auto text-sm text-gray-500"></span>
  </div>

  <!-- Upload progress / status -->
  <div id="upload-status" class="hidden mb-4"></div>

  <!-- Add Customer Modal -->
  <div id="add-customer-modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
       onclick="if(event.target===this)closeAddModal()">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800 text-lg">Add Customer</h2>
        <button onclick="closeAddModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>
      <form id="add-customer-form" onsubmit="submitAddCustomer(event)" class="px-6 py-5">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Full Name <span class="text-red-400">*</span></label>
            <input name="Full Name" type="text" required
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">DOB</label>
            <input name="DOB" type="text" placeholder="e.g. 01/01/1990"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Email</label>
            <input name="Email" type="email"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Telephone no</label>
            <input name="Telephone no" type="text"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Emergency contact</label>
            <input name="Emergency contact" type="text"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Waiver form (old)</label>
            <input name="Waiver form (old)" type="text"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Note</label>
            <input name="Note" type="text"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
        </div>
        <div id="add-customer-error"
             class="hidden mt-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
        <div class="flex justify-end gap-3 mt-5">
          <button type="button" onclick="closeAddModal()"
                  class="bg-white hover:bg-gray-50 border border-gray-300 text-gray-700
                         font-medium text-sm px-4 py-2 rounded-lg transition">Cancel</button>
          <button type="submit" id="add-customer-submit"
                  class="bg-orange-500 hover:bg-orange-600 text-white font-medium text-sm
                         px-5 py-2 rounded-lg transition">Add Customer</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Customer table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 overflow-x-auto">
    <div id="table-wrapper" class="hidden">
      <table id="customer-table" class="w-full" style="width:100%">
        <thead><tr></tr></thead>
        <tbody></tbody>
      </table>
    </div>
    <div id="no-data-msg" class="py-16 text-center text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/>
      </svg>
      <p class="text-sm">No customers yet. Import a CSV file to get started.</p>
    </div>
  </div>

  <script is:inline>
    var customerTable = null;
    var customerHeaders = [];
    var customerRows = [];
    var DEFAULT_HEADERS = ['Full Name', 'DOB', 'Email', 'Telephone no', 'Emergency contact', 'Note', 'Waiver form (old)'];

    // ── API helper ──
    function apiFetch(url, options) {
      var token = sessionStorage.getItem('bbo_token') || '';
      var defaults = { headers: { 'Authorization': 'Bearer ' + token } };
      if (options && options.body) {
        defaults.headers['Content-Type'] = 'application/json';
      }
      return fetch(url, Object.assign({}, defaults, options, {
        headers: Object.assign(defaults.headers, options && options.headers)
      }));
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeAddModal();
    });

    function openAddModal() {
      document.getElementById('add-customer-form').reset();
      document.getElementById('add-customer-error').classList.add('hidden');
      document.getElementById('add-customer-modal').classList.remove('hidden');
      // Focus the Full Name field
      setTimeout(function () {
        document.querySelector('#add-customer-form [name="Full Name"]').focus();
      }, 50);
    }

    function closeAddModal() {
      document.getElementById('add-customer-modal').classList.add('hidden');
    }

    function submitAddCustomer(e) {
      e.preventDefault();
      var form = document.getElementById('add-customer-form');
      var data = new FormData(form);
      var row = {};
      DEFAULT_HEADERS.forEach(function (h) { row[h] = data.get(h) || ''; });

      var errEl = document.getElementById('add-customer-error');
      errEl.classList.add('hidden');
      var submitBtn = document.getElementById('add-customer-submit');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Adding…';

      apiFetch('/api/customers', { method: 'PUT', body: JSON.stringify({ row: row }) })
        .then(function (res) { return res.json(); })
        .then(function (result) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Add Customer';
          if (result.error) {
            errEl.textContent = result.error;
            errEl.classList.remove('hidden');
            return;
          }
          closeAddModal();
          if (!customerHeaders.length) customerHeaders = DEFAULT_HEADERS.slice();
          customerRows.push(result.row);
          if (customerTable) {
            customerTable.row.add(result.row).draw();
          } else {
            renderTable();
          }
          updateCount();
          showToast('Customer added.', 'success');
        })
        .catch(function (err) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Add Customer';
          errEl.textContent = 'Failed: ' + err.message;
          errEl.classList.remove('hidden');
        });
    }

    $(document).ready(function () {
      loadCustomers();

      // CSV file input
      document.getElementById('csv-upload').addEventListener('change', function (e) {
        var file = e.target.files[0];
        if (!file) return;
        if (!file.name.toLowerCase().endsWith('.csv')) {
          showStatus('Please select a valid .csv file.', 'error');
          return;
        }
        var reader = new FileReader();
        reader.onload = function (ev) {
          processCSV(ev.target.result, file.name);
        };
        reader.readAsText(file, 'UTF-8');
        e.target.value = '';
      });
    });

    // ── Load customers from API ──
    function loadCustomers() {
      showStatus('Loading customers…', 'info', true);
      apiFetch('/api/customers')
        .then(function (res) { return res.json(); })
        .then(function (data) {
          document.getElementById('upload-status').classList.add('hidden');
          if (data.error) { showStatus(data.error, 'error'); return; }
          customerHeaders = data.headers || [];
          customerRows    = data.rows    || [];
          if (customerRows.length) renderTable();
          updateCount();
        })
        .catch(function (err) {
          showStatus('Failed to load customers: ' + err.message, 'error');
        });
    }

    // ── CSV Parsing (client-side read only) ──
    function parseCSV(text) {
      var rows = [];
      var lines = text.split(/\r\n|\n|\r/);
      for (var i = 0; i < lines.length; i++) {
        if (!lines[i].trim()) continue;
        rows.push(parseCSVLine(lines[i]));
      }
      return rows;
    }

    function parseCSVLine(line) {
      var row = [], current = '', inQ = false;
      for (var i = 0; i < line.length; i++) {
        var ch = line[i];
        if (ch === '"') {
          if (inQ && line[i + 1] === '"') { current += '"'; i++; }
          else { inQ = !inQ; }
        } else if (ch === ',' && !inQ) {
          row.push(current.trim()); current = '';
        } else { current += ch; }
      }
      row.push(current.trim());
      return row;
    }

    function processCSV(text, filename) {
      // Strip UTF-8 BOM (Excel/Google Sheets often adds \uFEFF at the start)
      text = text.replace(/^\uFEFF/, '');
      var rows = parseCSV(text);
      if (rows.length < 2) {
        showStatus('The CSV file appears to be empty or has only headers.', 'error');
        return;
      }
      var headers = rows[0].map(function (h) {
        return h.replace(/^["']|["']$/g, '').trim();
      }).filter(Boolean);
      if (!headers.length) {
        showStatus('No valid column headers found in the CSV.', 'error');
        return;
      }

      var csvRows = rows.slice(1).map(function (row) {
        var obj = {};
        headers.forEach(function (h, i) { obj[h] = row[i] !== undefined ? row[i] : ''; });
        return obj;
      });

      showStatus('Uploading ' + csvRows.length + ' customer(s)…', 'info', true);
      var btn = document.querySelector('[onclick="exportCustomers()"]');
      if (btn) btn.disabled = true;

      apiFetch('/api/customers', {
        method: 'POST',
        body: JSON.stringify({ rows: csvRows })
      })
        .then(function (res) {
          return res.text().then(function (t) {
            try { return JSON.parse(t); }
            catch (e) { return { error: 'Server error (HTTP ' + res.status + '): ' + t.slice(0, 120) }; }
          });
        })
        .then(function (data) {
          if (btn) btn.disabled = false;
          if (data.error) { showStatus(data.error, 'error'); return; }
          showStatus(
            'Imported <strong>' + data.count + '</strong> customer(s) from <strong>' + escHtml(filename) + '</strong>.',
            'success'
          );
          loadCustomers();
        })
        .catch(function (err) {
          if (btn) btn.disabled = false;
          showStatus('Upload failed: ' + err.message, 'error');
        });
    }

    function renderTable() {
      if (!customerHeaders.length) return;

      if ($.fn.DataTable.isDataTable('#customer-table')) {
        $('#customer-table').DataTable().destroy();
      }
      customerTable = null;
      document.querySelector('#customer-table thead tr').innerHTML = '';
      document.querySelector('#customer-table tbody').innerHTML    = '';

      document.getElementById('no-data-msg').classList.add('hidden');
      document.getElementById('table-wrapper').classList.remove('hidden');

      var cols = customerHeaders.map(function (h) {
        return {
          title: escHtml(h),
          data: (function (key) {
            return function (row) { return row[key] != null ? String(row[key]) : ''; };
          })(h),
          defaultContent: ''
        };
      });
      cols.push({
        title: 'Actions',
        data: null,
        orderable: false,
        searchable: false,
        render: function (data, type, row) {
          return '<button onclick="deleteCustomer(\'' + row._id + '\')" ' +
            'class="inline-flex items-center gap-1 text-xs text-red-500 hover:text-red-700 ' +
            'hover:bg-red-50 px-2 py-1 rounded transition">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" ' +
            'd="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>' +
            '</svg>Delete</button>';
        }
      });

      try {
        customerTable = $('#customer-table').DataTable({
          data: customerRows,
          columns: cols,
          dom: "<'flex flex-wrap items-center justify-between gap-3 mb-3'<'flex gap-2'B><'flex-1 text-right'f>>" +
               "t" +
               "<'flex flex-wrap items-center justify-between mt-3'<'text-sm text-gray-500'i><'flex gap-1'p>>",
          buttons: [{
            extend: 'csvHtml5',
            text: '⬇ Export CSV',
            title: 'Customer List',
            exportOptions: { columns: ':not(:last-child)' }
          }],
          order: [[0, 'asc']],
          pageLength: 25,
          scrollX: true,
          language: { emptyTable: 'No customer records found.' }
        });
      } catch (err) {
        customerTable = null;
        document.getElementById('table-wrapper').classList.add('hidden');
        document.getElementById('no-data-msg').classList.remove('hidden');
        showStatus('DataTables error: ' + escHtml(err.message), 'error', true);
      }
    }

    function deleteCustomer(id) {
      if (!confirm('Delete this customer? This action cannot be undone.')) return;
      apiFetch('/api/customers/' + id, { method: 'DELETE' })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.error) { showToast('Delete failed: ' + data.error, 'error'); return; }
          customerRows = customerRows.filter(function (c) { return c._id !== id; });
          if (customerTable) {
            customerTable.clear();
            customerTable.rows.add(customerRows);
            customerTable.draw();
          }
          updateCount();
          showToast('Customer deleted.', 'warning');
        })
        .catch(function (err) { showToast('Delete failed: ' + err.message, 'error'); });
    }

    function clearAllCustomers() {
      if (!confirm('Clear ALL customer data? This cannot be undone.')) return;
      apiFetch('/api/customers', {
        method: 'POST',
        body: JSON.stringify({ rows: [] })
      })
        .then(function (res) { return res.json(); })
        .then(function () {
          customerHeaders = [];
          customerRows    = [];
          if (customerTable) { customerTable.destroy(); customerTable = null; }
          document.querySelector('#customer-table thead tr').innerHTML = '';
          document.querySelector('#customer-table tbody').innerHTML = '';
          document.getElementById('table-wrapper').classList.add('hidden');
          document.getElementById('no-data-msg').classList.remove('hidden');
          updateCount();
          showToast('All customer data cleared.', 'warning');
        })
        .catch(function (err) { showToast('Clear failed: ' + err.message, 'error'); });
    }

    function exportCustomers() {
      if (!customerRows.length) {
        showStatus('No customer data to export.', 'error');
        return;
      }
      if (customerTable) $('.buttons-csv').trigger('click');
    }

    function updateCount() {
      var el = document.getElementById('customer-count');
      el.textContent = customerRows.length
        ? customerRows.length + ' customer' + (customerRows.length !== 1 ? 's' : '') + ' in database'
        : '';
    }

    function showStatus(msg, type, persistent) {
      var el = document.getElementById('upload-status');
      var colorClass = type === 'error'
        ? 'bg-red-50 border-red-200 text-red-700'
        : type === 'info'
        ? 'bg-blue-50 border-blue-200 text-blue-700'
        : 'bg-green-50 border-green-200 text-green-700';
      el.className = 'mb-4 px-4 py-3 rounded-xl border text-sm flex items-start justify-between gap-3 ' + colorClass;
      el.innerHTML = '<span>' + msg + '</span>' +
        '<button onclick="this.closest(\'#upload-status\').classList.add(\'hidden\')" ' +
        'class="shrink-0 font-bold text-lg leading-none opacity-60 hover:opacity-100">&times;</button>';
      el.classList.remove('hidden');
      if (!persistent) setTimeout(function () { el.classList.add('hidden'); }, 6000);
    }

    function showToast(msg, type) {
      var t = document.createElement('div');
      t.textContent = msg;
      t.className = 'fixed bottom-6 right-6 z-50 px-4 py-2.5 rounded-lg text-sm font-medium shadow-lg ' +
        (type === 'warning' ? 'bg-yellow-500 text-white' : type === 'error' ? 'bg-red-500 text-white' : 'bg-green-500 text-white');
      document.body.appendChild(t);
      setTimeout(function () { t.remove(); }, 2500);
    }

    function escHtml(str) {
      return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
  </script>
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Customers" activePage="customers">
<div>

  <!-- ── Customer Stats Panel ─────────────────────────────────────────── -->
  <div class="mb-6 space-y-4">

    <!-- Stat Cards Row -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

      <!-- New Customers Card -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <div class="flex items-start justify-between gap-3 mb-4">
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">New Customers</p>
            <div class="flex items-baseline gap-1.5">
              <span id="stat-new-count" class="text-3xl font-bold text-gray-800">—</span>
              <span id="stat-new-sub"   class="text-xs text-gray-400"></span>
            </div>
          </div>
          <div class="shrink-0 p-2.5 bg-orange-50 rounded-xl">
            <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
            </svg>
          </div>
        </div>
        <div class="flex items-center gap-1.5">
          <input type="date" id="new-cust-from"
                 class="flex-1 min-w-0 border border-gray-200 rounded-lg px-2.5 py-1.5 text-xs
                        focus:outline-none focus:ring-2 focus:ring-orange-300" />
          <span class="text-gray-300 text-xs shrink-0">to</span>
          <input type="date" id="new-cust-to"
                 class="flex-1 min-w-0 border border-gray-200 rounded-lg px-2.5 py-1.5 text-xs
                        focus:outline-none focus:ring-2 focus:ring-orange-300" />
          <button onclick="fetchNewCustomerStat()"
                  class="shrink-0 bg-orange-500 hover:bg-orange-600 text-white text-xs font-medium
                         px-3 py-1.5 rounded-lg transition">Apply</button>
        </div>
      </div>

      <!-- Returned Customers Card -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <div class="flex items-start justify-between gap-3 mb-4">
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Returned Customers</p>
            <div class="flex items-baseline gap-1.5">
              <span id="stat-ret-pct" class="text-3xl font-bold text-gray-800">—</span>
              <span id="stat-ret-sub" class="text-xs text-gray-400"></span>
            </div>
          </div>
          <div class="shrink-0 p-2.5 bg-green-50 rounded-xl">
            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
        </div>
        <div class="flex items-center gap-1.5">
          <input type="date" id="ret-from"
                 class="flex-1 min-w-0 border border-gray-200 rounded-lg px-2.5 py-1.5 text-xs
                        focus:outline-none focus:ring-2 focus:ring-orange-300" />
          <span class="text-gray-300 text-xs shrink-0">to</span>
          <input type="date" id="ret-to"
                 class="flex-1 min-w-0 border border-gray-200 rounded-lg px-2.5 py-1.5 text-xs
                        focus:outline-none focus:ring-2 focus:ring-orange-300" />
          <button onclick="fetchReturnedStat()"
                  class="shrink-0 bg-orange-500 hover:bg-orange-600 text-white text-xs font-medium
                         px-3 py-1.5 rounded-lg transition">Apply</button>
        </div>
      </div>

    </div><!-- /Stat Cards Row -->

    <!-- Check-in Activity Heatmap -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Check-in Activity</p>
        <div class="flex flex-wrap items-center gap-2">
          <!-- Period tabs -->
          <div class="flex rounded-lg border border-gray-200 overflow-hidden text-xs font-medium">
            <button id="hm-btn-week"   onclick="setHeatmapPeriod('week')"
                    class="px-3 py-1.5 bg-orange-500 text-white">Week</button>
            <button id="hm-btn-month"  onclick="setHeatmapPeriod('month')"
                    class="px-3 py-1.5 text-gray-600 hover:bg-gray-50 border-l border-gray-200">Month</button>
            <button id="hm-btn-year"   onclick="setHeatmapPeriod('year')"
                    class="px-3 py-1.5 text-gray-600 hover:bg-gray-50 border-l border-gray-200">Year</button>
            <button id="hm-btn-custom" onclick="setHeatmapPeriod('custom')"
                    class="px-3 py-1.5 text-gray-600 hover:bg-gray-50 border-l border-gray-200">Custom</button>
          </div>
          <!-- Custom date inputs (shown only when "Custom" is active) -->
          <div id="hm-custom-row" class="hidden flex items-center gap-1.5">
            <input type="date" id="hm-from"
                   class="border border-gray-200 rounded-lg px-2 py-1 text-xs
                          focus:outline-none focus:ring-2 focus:ring-orange-300" />
            <span class="text-gray-300 text-xs">to</span>
            <input type="date" id="hm-to"
                   class="border border-gray-200 rounded-lg px-2 py-1 text-xs
                          focus:outline-none focus:ring-2 focus:ring-orange-300" />
            <button onclick="fetchHeatmap()"
                    class="bg-orange-500 hover:bg-orange-600 text-white text-xs font-medium
                           px-3 py-1 rounded-lg transition">Apply</button>
          </div>
        </div>
      </div>

      <!-- Loading spinner -->
      <div id="hm-loading" class="hidden py-6 flex justify-center">
        <div class="w-6 h-6 border-2 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
      </div>

      <!-- Heatmap grid (rendered by ApexCharts) -->
      <div id="heatmap-container"></div>
    </div><!-- /Heatmap -->

  </div><!-- /Stats Panel -->

  <!-- Action bar -->
  <div class="flex flex-wrap items-center gap-3 mb-6">
    <!-- Upload CSV -->
    <label for="csv-upload"
           class="inline-flex items-center gap-2 cursor-pointer bg-orange-500 hover:bg-orange-600
                  text-white font-medium text-sm px-4 py-2.5 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
      </svg>
      Import CSV
    </label>
    <input type="file" id="csv-upload" accept=".csv" class="hidden" />

    <!-- Add Customer -->
    <button onclick="openAddModal()"
            class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600
                   text-white font-medium text-sm px-4 py-2.5 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Add Customer
    </button>

    <!-- Export CSV -->
    <button onclick="exportCustomers()"
            class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 border border-gray-300
                   text-gray-700 font-medium text-sm px-4 py-2.5 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      Export CSV
    </button>

    <!-- Column visibility -->
    <div class="relative" id="columns-btn-wrapper">
      <button onclick="toggleColumnsDropdown()" id="columns-toggle-btn"
              class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 border border-gray-300
                     text-gray-700 font-medium text-sm px-4 py-2.5 rounded-lg transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/>
        </svg>
        Columns
      </button>
      <div id="columns-dropdown"
           class="hidden absolute left-0 top-full mt-1 z-40 bg-white border border-gray-200
                  rounded-xl shadow-lg py-2 px-3 min-w-[12rem]">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2 px-1">Show / Hide Columns</p>
        <p id="columns-empty" class="text-xs text-gray-400 px-1">Load customers first.</p>
        <div id="columns-checklist" class="space-y-0.5"></div>
      </div>
    </div>

    <!-- Clear all -->
    <button onclick="clearAllCustomers()"
            class="inline-flex items-center gap-2 bg-white hover:bg-red-50 border border-gray-300
                   hover:border-red-300 text-gray-500 hover:text-red-600 font-medium text-sm
                   px-4 py-2.5 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
      Clear All
    </button>

    <span id="customer-count" class="ml-auto text-sm text-gray-500"></span>
  </div>

  <!-- Upload progress / status -->
  <div id="upload-status" class="hidden mb-4"></div>

  <!-- Import Confirmation Modal -->
  <div id="import-confirm-modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800 text-lg">Confirm CSV Import</h2>
        <button onclick="closeImportConfirmModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>
      <div class="px-6 py-5 space-y-4">
        <div id="import-confirm-info" class="text-sm text-gray-700"></div>
        <p class="text-xs text-gray-400">Customers already in the database (matched by email or name) will be skipped. No existing records will be deleted.</p>
        <div class="flex justify-end gap-3 pt-1">
          <button type="button" onclick="closeImportConfirmModal()"
                  class="bg-white hover:bg-gray-50 border border-gray-300 text-gray-700
                         font-medium text-sm px-4 py-2 rounded-lg transition">Cancel</button>
          <button id="import-confirm-btn" onclick="confirmImport()"
                  class="bg-orange-500 hover:bg-orange-600 text-white font-medium text-sm
                         px-5 py-2 rounded-lg transition">Import</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Customer Modal -->
  <div id="add-customer-modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
       onclick="if(event.target===this)closeAddModal()">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800 text-lg">Add Customer</h2>
        <button onclick="closeAddModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>
      <form id="add-customer-form" onsubmit="submitAddCustomer(event)" class="px-6 py-5">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Full Name <span class="text-red-400">*</span></label>
            <input name="Full Name" type="text" required
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">DOB</label>
            <input name="DOB" type="text" placeholder="e.g. 01/01/1990"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Email</label>
            <input name="Email" type="email"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Telephone no</label>
            <input name="Telephone no" type="text"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Emergency contact</label>
            <input name="Emergency contact" type="text"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Waiver form (old)</label>
            <input name="Waiver form (old)" type="text"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Note</label>
            <input name="Note" type="text"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" />
          </div>
        </div>
        <div id="add-customer-error"
             class="hidden mt-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
        <div class="flex justify-end gap-3 mt-5">
          <button type="button" onclick="closeAddModal()"
                  class="bg-white hover:bg-gray-50 border border-gray-300 text-gray-700
                         font-medium text-sm px-4 py-2 rounded-lg transition">Cancel</button>
          <button type="submit" id="add-customer-submit"
                  class="bg-orange-500 hover:bg-orange-600 text-white font-medium text-sm
                         px-5 py-2 rounded-lg transition">Add Customer</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Membership Modal -->
  <div id="edit-membership-modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
       onclick="if(event.target===this)closeEditMembershipModal()">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800 text-lg">Membership — <span id="edit-membership-name" class="text-orange-500"></span></h2>
        <button onclick="closeEditMembershipModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>
      <div class="px-6 py-5 space-y-4">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Membership Type</label>
          <select id="edit-membership-type"
                  class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                         focus:outline-none focus:ring-2 focus:ring-orange-300"
                  onchange="document.getElementById('edit-membership-start-row').classList.toggle('hidden', !this.value)">
            <option value="">— No membership —</option>
            <option value="1 Month">1 Month</option>
            <option value="3 Months">3 Months</option>
            <option value="6 Months">6 Months</option>
            <option value="12 Months">12 Months</option>
          </select>
        </div>
        <div id="edit-membership-start-row" class="hidden">
          <label class="block text-xs font-medium text-gray-600 mb-1">Start Date</label>
          <input id="edit-membership-start" type="date"
                 class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-orange-300" />
          <p class="text-xs text-gray-400 mt-1">End date is calculated automatically.</p>
        </div>
        <div id="edit-membership-error"
             class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
        <div class="flex justify-end gap-3 pt-1">
          <button type="button" onclick="closeEditMembershipModal()"
                  class="bg-white hover:bg-gray-50 border border-gray-300 text-gray-700
                         font-medium text-sm px-4 py-2 rounded-lg transition">Cancel</button>
          <button id="edit-membership-submit" onclick="submitEditMembership()"
                  class="bg-orange-500 hover:bg-orange-600 text-white font-medium text-sm
                         px-5 py-2 rounded-lg transition">Save</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Punch Card Modal -->
  <div id="edit-punch-modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
       onclick="if(event.target===this)closeEditPunchModal()">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800 text-lg">Punch Card — <span id="edit-punch-name" class="text-orange-500"></span></h2>
        <button onclick="closeEditPunchModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>
      <div class="px-6 py-5 space-y-4">
        <div class="flex items-center gap-3">
          <input id="edit-punch-holder" type="checkbox"
                 class="w-4 h-4 rounded accent-orange-500"
                 onchange="document.getElementById('edit-punch-count-row').classList.toggle('hidden', !this.checked)" />
          <label for="edit-punch-holder" class="text-sm font-medium text-gray-700">Is Punch Card Holder</label>
        </div>
        <div id="edit-punch-count-row" class="hidden">
          <label class="block text-xs font-medium text-gray-600 mb-1">Punches Remaining</label>
          <input id="edit-punch-count" type="number" min="0" step="1" value="0"
                 class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-orange-300" />
        </div>
        <div id="edit-punch-error"
             class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
        <div class="flex justify-end gap-3 pt-1">
          <button type="button" onclick="closeEditPunchModal()"
                  class="bg-white hover:bg-gray-50 border border-gray-300 text-gray-700
                         font-medium text-sm px-4 py-2 rounded-lg transition">Cancel</button>
          <button id="edit-punch-submit" onclick="submitEditPunchCard()"
                  class="bg-orange-500 hover:bg-orange-600 text-white font-medium text-sm
                         px-5 py-2 rounded-lg transition">Save</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Customer table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 overflow-x-auto">
    <!-- Loading spinner -->
    <div id="table-loading" class="hidden py-16 flex flex-col items-center justify-center gap-3">
      <div class="w-10 h-10 border-4 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
      <p class="text-sm text-gray-400">Loading customers…</p>
    </div>
    <div id="table-wrapper" class="hidden">
      <table id="customer-table" class="w-full" style="width:100%">
        <thead><tr></tr></thead>
        <tbody></tbody>
      </table>
    </div>
    <div id="no-data-msg" class="py-16 text-center text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/>
      </svg>
      <p class="text-sm">No customers yet. Import a CSV file to get started.</p>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
  <script is:inline>
    // ═══════════════════════════════════════════════════════════════════════
    // ── Stats Panel ─────────────────────────────────────────────────────────
    // ═══════════════════════════════════════════════════════════════════════
    var _hmPeriod = 'week';
    var _hmChart  = null;
    var MONTH_NAMES = ['January','February','March','April','May','June',
                       'July','August','September','October','November','December'];

    function _fmtDate(d) {
      return d.getFullYear() + '-' +
        String(d.getMonth() + 1).padStart(2, '0') + '-' +
        String(d.getDate()).padStart(2, '0');
    }

    function _todayStr() {
      return _fmtDate(new Date());
    }

    function _thisMonthRange() {
      var now  = new Date();
      var from = new Date(now.getFullYear(), now.getMonth(), 1);
      var to   = new Date(now.getFullYear(), now.getMonth() + 1, 0);
      return { from: _fmtDate(from), to: _fmtDate(to) };
    }

    function initStatDefaults() {
      var r = _thisMonthRange();
      document.getElementById('new-cust-from').value = r.from;
      document.getElementById('new-cust-to').value   = r.to;
      document.getElementById('ret-from').value      = r.from;
      document.getElementById('ret-to').value        = r.to;
    }

    // ── New Customers stat card ──────────────────────────────────────────────
    function fetchNewCustomerStat() {
      var from = document.getElementById('new-cust-from').value;
      var to   = document.getElementById('new-cust-to').value;
      if (!from || !to) return;
      document.getElementById('stat-new-count').textContent = '…';
      document.getElementById('stat-new-sub').textContent   = '';
      apiFetch('/api/customers/stats?stats_from=' + from + '&stats_to=' + to)
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.error) {
            document.getElementById('stat-new-count').textContent = '!';
            document.getElementById('stat-new-sub').textContent   = data.error;
            return;
          }
          document.getElementById('stat-new-count').textContent = data.new_customers;
          document.getElementById('stat-new-sub').textContent   = _formatRange(from, to);
        })
        .catch(function () {
          document.getElementById('stat-new-count').textContent = '!';
          document.getElementById('stat-new-sub').textContent   = 'Error loading';
        });
    }

    // ── Returned Customers stat card ─────────────────────────────────────────
    function fetchReturnedStat() {
      var from = document.getElementById('ret-from').value;
      var to   = document.getElementById('ret-to').value;
      if (!from || !to) return;
      document.getElementById('stat-ret-pct').textContent = '…';
      document.getElementById('stat-ret-sub').textContent = '';
      apiFetch('/api/customers/stats?stats_from=' + from + '&stats_to=' + to)
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.error) {
            document.getElementById('stat-ret-pct').textContent = '!';
            document.getElementById('stat-ret-sub').textContent = data.error;
            return;
          }
          if (data.returned_pct === null || data.total_period_visitors === 0) {
            document.getElementById('stat-ret-pct').textContent = 'N/A';
            document.getElementById('stat-ret-sub').textContent = 'No visitors this period';
          } else {
            document.getElementById('stat-ret-pct').textContent = data.returned_pct + '%';
            document.getElementById('stat-ret-sub').textContent =
              data.returned_count + ' of ' + data.total_period_visitors + ' visitors';
          }
        })
        .catch(function () {
          document.getElementById('stat-ret-pct').textContent = '!';
          document.getElementById('stat-ret-sub').textContent = 'Error loading';
        });
    }

    function _formatRange(from, to) {
      var f = new Date(from + 'T00:00:00');
      var t = new Date(to   + 'T00:00:00');
      var ms = MONTH_NAMES.map(function (m) { return m.slice(0, 3); });
      return ms[f.getMonth()] + ' ' + f.getDate() +
             ' – ' + ms[t.getMonth()] + ' ' + t.getDate() + ', ' + t.getFullYear();
    }

    // ── Heatmap ──────────────────────────────────────────────────────────────
    function setHeatmapPeriod(period) {
      _hmPeriod = period;
      ['week', 'month', 'year', 'custom'].forEach(function (p) {
        var btn = document.getElementById('hm-btn-' + p);
        if (p === period) {
          btn.classList.add('bg-orange-500', 'text-white');
          btn.classList.remove('text-gray-600', 'hover:bg-gray-50');
        } else {
          btn.classList.remove('bg-orange-500', 'text-white');
          btn.classList.add('text-gray-600', 'hover:bg-gray-50');
        }
      });
      document.getElementById('hm-custom-row').classList.toggle('hidden', period !== 'custom');
      if (period !== 'custom') fetchHeatmap();
    }

    function _getHeatmapRange() {
      var today = new Date();
      if (_hmPeriod === 'week') {
        var dow = today.getDay();
        var mon = new Date(today);
        mon.setDate(today.getDate() - (dow === 0 ? 6 : dow - 1));
        var sun = new Date(mon);
        sun.setDate(mon.getDate() + 6);
        return { from: _fmtDate(mon), to: _fmtDate(sun) };
      }
      if (_hmPeriod === 'month') {
        return _thisMonthRange();
      }
      if (_hmPeriod === 'year') {
        var y = today.getFullYear();
        return { from: y + '-01-01', to: y + '-12-31' };
      }
      // custom
      return {
        from: document.getElementById('hm-from').value,
        to:   document.getElementById('hm-to').value
      };
    }

    function fetchHeatmap() {
      if (_hmChart) { _hmChart.destroy(); _hmChart = null; }
      var range = _getHeatmapRange();
      if (!range.from || !range.to) return;
      document.getElementById('hm-loading').classList.remove('hidden');
      document.getElementById('heatmap-container').innerHTML = '';
      apiFetch('/api/customers/stats?hm_from=' + range.from + '&hm_to=' + range.to)
        .then(function (res) { return res.json(); })
        .then(function (data) {
          document.getElementById('hm-loading').classList.add('hidden');
          if (data.error) {
            document.getElementById('heatmap-container').innerHTML =
              '<p class="text-sm text-red-500 py-4">Failed to load: ' + escHtml(data.error) + '</p>';
            return;
          }
          var dateMap = {};
          (data.heatmap || []).forEach(function (d) { dateMap[d.date] = d.count; });
          var start = new Date(range.from + 'T00:00:00');
          var end   = new Date(range.to   + 'T00:00:00');
          _renderHeatmap(dateMap, start, end);
        })
        .catch(function () {
          document.getElementById('hm-loading').classList.add('hidden');
          document.getElementById('heatmap-container').innerHTML =
            '<p class="text-sm text-red-500 py-4">Failed to load heatmap.</p>';
        });
    }

    // ── Heatmap rendering with ApexCharts ──────────────────────────────────
    function _renderHeatmap(dateMap, startDate, endDate) {
      if (_hmChart) { _hmChart.destroy(); _hmChart = null; }
      document.getElementById('heatmap-container').innerHTML = '';
      if (_hmPeriod === 'week') {
        _renderApexWeekBar(dateMap, startDate);
      } else {
        _renderApexGrid(dateMap, startDate, endDate);
      }
    }

    // Week view: bar chart Mon–Sun
    function _renderApexWeekBar(dateMap, startDate) {
      var DAY_LABELS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
      var categories = [];
      var counts     = [];
      for (var i = 0; i < 7; i++) {
        var d = new Date(startDate);
        d.setDate(startDate.getDate() + i);
        categories.push(DAY_LABELS[i] + ' ' + (d.getMonth() + 1) + '/' + d.getDate());
        counts.push(dateMap[_fmtDate(d)] || 0);
      }
      _hmChart = new ApexCharts(document.getElementById('heatmap-container'), {
        chart: {
          type: 'bar', height: 200,
          toolbar: { show: false },
          fontFamily: 'Inter, system-ui, sans-serif'
        },
        series: [{ name: 'Check-ins', data: counts }],
        xaxis: { categories: categories, labels: { style: { fontSize: '11px', colors: '#6b7280' } } },
        yaxis: { min: 0, forceNiceScale: true, labels: { style: { fontSize: '11px', colors: '#6b7280' } } },
        colors: ['#f97316'],
        plotOptions: {
          bar: { borderRadius: 5, columnWidth: '55%', distributed: true, dataLabels: { position: 'top' } }
        },
        dataLabels: {
          enabled: true, offsetY: -18,
          style: { fontSize: '11px', colors: ['#4b5563'] }
        },
        legend: { show: false },
        grid: { strokeDashArray: 4, borderColor: '#f3f4f6' },
        tooltip: { y: { formatter: function (v) { return v + ' check-in' + (v !== 1 ? 's' : ''); } } }
      });
      _hmChart.render();
    }

    // Month / Year / Custom: GitHub-style heatmap (weeks = columns, days = rows)
    function _renderApexGrid(dateMap, startDate, endDate) {
      // ApexCharts stacks series bottom-to-top, so reverse day order: Mon appears on top
      var DAY_NAMES_REV   = ['Sun', 'Sat', 'Fri', 'Thu', 'Wed', 'Tue', 'Mon'];
      var DAY_OFFSETS_REV = [6, 5, 4, 3, 2, 1, 0]; // offset from week-start Monday

      var gridStart = new Date(startDate);
      var dow = gridStart.getDay();
      gridStart.setDate(gridStart.getDate() - (dow === 0 ? 6 : dow - 1));

      var weekStarts = [];
      var cur = new Date(gridStart);
      while (cur <= endDate) {
        weekStarts.push(new Date(cur));
        cur.setDate(cur.getDate() + 7);
      }

      var series = DAY_NAMES_REV.map(function (name, ri) {
        var offset = DAY_OFFSETS_REV[ri];
        return {
          name: name,
          data: weekStarts.map(function (ws) {
            var d = new Date(ws);
            d.setDate(ws.getDate() + offset);
            var inRange = d >= startDate && d <= endDate;
            return { x: (d.getMonth() + 1) + '/' + d.getDate(), y: inRange ? (dateMap[_fmtDate(d)] || 0) : null };
          })
        };
      });

      // Show month abbreviation only on the first week of each month
      var xCategories = weekStarts.map(function (ws) {
        return ws.getDate() <= 7 ? MONTH_NAMES[ws.getMonth()].slice(0, 3) : '';
      });

      _hmChart = new ApexCharts(document.getElementById('heatmap-container'), {
        chart: {
          type: 'heatmap', height: 185,
          toolbar: { show: false },
          fontFamily: 'Inter, system-ui, sans-serif',
          animations: { enabled: false }
        },
        series: series,
        dataLabels: { enabled: false },
        legend: { show: false },
        xaxis: {
          categories: xCategories,
          labels: {
            rotate: 0,
            style: { fontSize: '10px', colors: '#9ca3af' },
            formatter: function (v) { return v || ''; }
          },
          axisBorder: { show: false },
          axisTicks: { show: false }
        },
        yaxis: { labels: { style: { fontSize: '11px', colors: '#6b7280' } } },
        plotOptions: {
          heatmap: {
            radius: 3,
            enableShades: false,
            colorScale: {
              ranges: [
                { from: 0,   to: 0,    color: '#f3f4f6', name: 'None' },
                { from: 1,   to: 2,    color: '#ffedd5', name: '1-2'  },
                { from: 3,   to: 5,    color: '#fdba74', name: '3-5'  },
                { from: 6,   to: 10,   color: '#fb923c', name: '6-10' },
                { from: 11,  to: 9999, color: '#ea580c', name: '11+'  }
              ]
            }
          }
        },
        tooltip: {
          custom: function (opts) {
            var sd = opts.w.config.series[opts.seriesIndex].data[opts.dataPointIndex];
            var v  = sd ? sd.y : null;
            if (v === null || v === undefined) return '';
            var day = opts.w.config.series[opts.seriesIndex].name;
            return '<div style="padding:6px 10px;font-family:Inter,sans-serif;font-size:12px">' +
              '<strong>' + (sd.x || '') + ' (' + day + ')</strong>: ' +
              v + ' check-in' + (v !== 1 ? 's' : '') + '</div>';
          }
        }
      });
      _hmChart.render();
    }

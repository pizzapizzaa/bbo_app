    var customerTable = null;
    var customerHeaders = [];
    var customerRows = [];
    var DEFAULT_HEADERS = ['Full Name', 'DOB', 'Email', 'Telephone no', 'Emergency contact', 'Note', 'Waiver form (old)'];

    // ── Column visibility ──
    var hiddenColumns = [];
    var ALWAYS_HIDDEN_COLS = ['Waiver form (old)'];

    function loadHiddenColumns() {
      try {
        var stored = localStorage.getItem('bbo_hidden_cols');
        hiddenColumns = stored ? JSON.parse(stored) : [];
        if (!Array.isArray(hiddenColumns)) hiddenColumns = [];
      } catch (e) { hiddenColumns = []; }
    }

    function saveHiddenColumns() {
      try { localStorage.setItem('bbo_hidden_cols', JSON.stringify(hiddenColumns)); } catch (e) {}
    }

    function getAllColumnHeaders() {
      return customerHeaders.filter(function (h) { return ALWAYS_HIDDEN_COLS.indexOf(h) === -1; });
    }

    function toggleColumnsDropdown() {
      var dd = document.getElementById('columns-dropdown');
      if (dd.classList.contains('hidden')) {
        buildColumnsChecklist();
        dd.classList.remove('hidden');
      } else {
        dd.classList.add('hidden');
      }
    }

    function closeColumnsDropdown() {
      document.getElementById('columns-dropdown').classList.add('hidden');
    }

    function buildColumnsChecklist() {
      var checklist = document.getElementById('columns-checklist');
      var emptyMsg  = document.getElementById('columns-empty');
      var allCols   = getAllColumnHeaders();
      if (!allCols.length) {
        emptyMsg.classList.remove('hidden');
        checklist.innerHTML = '';
        return;
      }
      emptyMsg.classList.add('hidden');
      checklist.innerHTML = allCols.map(function (h) {
        var isHidden = hiddenColumns.indexOf(h) !== -1;
        var idSafe   = 'col-chk-' + h.replace(/[^a-z0-9]/gi, '-').toLowerCase();
        return '<label class="flex items-center gap-2 px-1 py-0.5 rounded hover:bg-gray-50 cursor-pointer select-none">' +
          '<input type="checkbox" id="' + idSafe + '" ' + (isHidden ? '' : 'checked') + ' ' +
          'onchange="toggleColumnVisibility(\'' + h.replace(/'/g, "\\'") + '\', this.checked)" ' +
          'class="w-3.5 h-3.5 rounded accent-orange-500" />' +
          '<span class="text-sm text-gray-700">' + escHtml(h) + '</span>' +
          '</label>';
      }).join('');
    }

    function toggleColumnVisibility(header, visible) {
      if (visible) {
        hiddenColumns = hiddenColumns.filter(function (h) { return h !== header; });
      } else {
        if (hiddenColumns.indexOf(header) === -1) hiddenColumns.push(header);
      }
      saveHiddenColumns();
      if (customerTable) {
        var allDisplayCols = getAllColumnHeaders();
        var colIdx = allDisplayCols.indexOf(header);
        if (colIdx !== -1) customerTable.column(colIdx).visible(visible);
      }
    }


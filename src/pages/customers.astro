    function confirmImport() {
      var csvRows  = _pendingImportRows;
      var filename = _pendingImportFilename;
      closeImportConfirmModal();

      showStatus('Uploading ' + csvRows.length + ' customer(s)…', 'info', true);
      var btn = document.querySelector('[onclick="exportCustomers()"]');
      if (btn) btn.disabled = true;

      apiFetch('/api/customers', {
        method: 'POST',
        body: JSON.stringify({ rows: csvRows })
      })
        .then(function (res) {
          return res.text().then(function (t) {
            try { return JSON.parse(t); }
            catch (e) { return { error: 'Server error (HTTP ' + res.status + '): ' + t.slice(0, 120) }; }
          });
        })
        .then(function (data) {
          if (btn) btn.disabled = false;
          if (data.error) { showStatus(data.error, 'error'); return; }
          var msg = 'Added <strong>' + data.added + '</strong> new customer(s) from <strong>' + escHtml(filename) + '</strong>.';
          if (data.skipped > 0) msg += ' <span class="text-gray-500">' + data.skipped + ' duplicate(s) skipped.</span>';
          showStatus(msg, 'success');
          loadCustomers();
        })
        .catch(function (err) {
          if (btn) btn.disabled = false;
          showStatus('Upload failed: ' + err.message, 'error');
        });
    }

    function renderTable() {
      if (!customerHeaders.length) return;

      if ($.fn.DataTable.isDataTable('#customer-table')) {
        $('#customer-table').DataTable().destroy();
      }
      customerTable = null;
      document.querySelector('#customer-table thead tr').innerHTML = '';
      document.querySelector('#customer-table tbody').innerHTML    = '';

      document.getElementById('no-data-msg').classList.add('hidden');
      document.getElementById('table-wrapper').classList.remove('hidden');

      var HIDDEN_COLS = ['Waiver form (old)'];
      var visibleHeaders = customerHeaders.filter(function (h) { return HIDDEN_COLS.indexOf(h) === -1; });

      var cols = visibleHeaders.map(function (h) {
        return {
          title: escHtml(h),
          data: (function (key) {
            return function (row) { return row[key] != null ? String(row[key]) : ''; };
          })(h),
          defaultContent: ''
        };
      });
      // Handle special Punch Card / Membership columns
      var finalCols = cols.map(function (col, i) {
        var h = visibleHeaders[i];
        if (h === 'Punch Card') {
          return Object.assign({}, col, {
            render: function (val, type, row) {
              if (type !== 'display') return val;
              var yes = row._is_punch_card_holder;
              return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ' +
                (yes ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500') + '">' +
                (yes ? 'Yes' : 'No') + '</span>';
            }
          });
        }
        if (h === 'Punches') {
          return Object.assign({}, col, {
            render: function (val, type, row) {
              if (type !== 'display') return val;
              if (!row._is_punch_card_holder) return '<span class="text-gray-300">—</span>';
              return '<span class="font-semibold ' + (row._punches_remaining > 0 ? 'text-green-600' : 'text-red-500') + '">' +
                row._punches_remaining + '</span>';
            }
          });
        }
        if (h === 'Membership') {
          return Object.assign({}, col, {
            render: function (val, type, row) {
              if (type !== 'display') return val;
              if (!row._membership_type) return '<span class="text-gray-300">—</span>';
              var end   = row._membership_end_date;
              var today = new Date().toISOString().slice(0, 10);
              var active = end && end >= today;
              return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ' +
                (active ? 'bg-blue-100 text-blue-700' : 'bg-red-100 text-red-600') + '">' +
                escHtml(row._membership_type) + '</span>';
            }
          });
        }
        if (h === 'Member Until') {
          return Object.assign({}, col, {
            render: function (val, type, row) {
              if (type !== 'display') return val;
              if (!row._membership_end_date) return '<span class="text-gray-300">—</span>';
              var today  = new Date().toISOString().slice(0, 10);
              var active = row._membership_end_date >= today;
              return '<span class="text-xs font-medium ' + (active ? 'text-blue-600' : 'text-red-500') + '">' +
                escHtml(row._membership_end_date) + '</span>';
            }
          });
        }
        return col;
      });

      finalCols.push({
        title: 'Actions',
        data: null,
        orderable: false,
        searchable: false,
        render: function (data, type, row) {
          return '<div class="flex items-center gap-1.5">' +
            '<button onclick="openEditMembership(\'' + row._id + '\')" ' +
            'class="inline-flex items-center gap-1 text-xs text-teal-500 hover:text-teal-700 ' +
            'hover:bg-teal-50 px-2 py-1 rounded transition" title="Edit membership">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" ' +
            'd="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/>' +
            '</svg>Mbr</button>' +
            '<button onclick="openEditPunchCard(\'' + row._id + '\')" ' +
            'class="inline-flex items-center gap-1 text-xs text-blue-500 hover:text-blue-700 ' +
            'hover:bg-blue-50 px-2 py-1 rounded transition" title="Edit punch card">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" ' +
            'd="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>' +
            '</svg>Punch</button>' +
            '<button onclick="deleteCustomer(\'' + row._id + '\')" ' +
            'class="inline-flex items-center gap-1 text-xs text-red-500 hover:text-red-700 ' +
            'hover:bg-red-50 px-2 py-1 rounded transition">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" ' +
            'd="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>' +
            '</svg>Delete</button></div>';
        }
      });

      try {
        customerTable = $('#customer-table').DataTable({
          data: customerRows,
          columns: finalCols,
          dom: "<'flex flex-wrap items-center gap-3 mb-3'<''f>>" +
               "t" +
               "<'flex flex-wrap items-center justify-between mt-3'<'text-sm text-gray-500'i><'flex gap-1'p>>",
          order: [[0, 'asc']],
          pageLength: 25,
          language: { emptyTable: 'No customer records found.' }
        });

        // Apply persisted column visibility
        if (hiddenColumns.length) {
          var allDisplayCols = getAllColumnHeaders();
          hiddenColumns.forEach(function (h) {
            var idx = allDisplayCols.indexOf(h);
            if (idx !== -1) customerTable.column(idx).visible(false);
          });
        }
      } catch (err) {
        customerTable = null;
        document.getElementById('table-wrapper').classList.add('hidden');
        document.getElementById('no-data-msg').classList.remove('hidden');
        showStatus('DataTables error: ' + escHtml(err.message), 'error', true);
      }
    }

    function deleteCustomer(id) {
      if (!confirm('Delete this customer? This action cannot be undone.')) return;
      apiFetch('/api/customers/' + id, { method: 'DELETE' })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.error) { showToast('Delete failed: ' + data.error, 'error'); return; }
          customerRows = customerRows.filter(function (c) { return c._id !== id; });
          if (customerTable) {
            customerTable.clear();
            customerTable.rows.add(customerRows);
            customerTable.draw();
          }
          updateCount();
          showToast('Customer deleted.', 'warning');
        })
        .catch(function (err) { showToast('Delete failed: ' + err.message, 'error'); });
    }

    function clearAllCustomers() {
      if (!confirm('Clear ALL customer data? This cannot be undone.')) return;
      apiFetch('/api/customers', { method: 'DELETE' })
        .then(function (res) { return res.json(); })
        .then(function () {
          customerHeaders = [];
          customerRows    = [];
          if (customerTable) { customerTable.destroy(); customerTable = null; }
          document.querySelector('#customer-table thead tr').innerHTML = '';
          document.querySelector('#customer-table tbody').innerHTML = '';
          document.getElementById('table-wrapper').classList.add('hidden');
          document.getElementById('no-data-msg').classList.remove('hidden');
          updateCount();
          showToast('All customer data cleared.', 'warning');
        })
        .catch(function (err) { showToast('Clear failed: ' + err.message, 'error'); });
    }

    function exportCustomers() {
      if (!customerRows.length) {
        showStatus('No customer data to export.', 'error');
        return;
      }
      var headers = DEFAULT_HEADERS;
      var lines = [headers.map(function (h) { return '"' + h.replace(/"/g, '""') + '"'; }).join(',')];
      customerRows.forEach(function (row) {
        lines.push(headers.map(function (h) {
          var v = row[h] != null ? String(row[h]) : '';
          return '"' + v.replace(/"/g, '""') + '"';
        }).join(','));
      });
      var blob = new Blob([lines.join('\r\n')], { type: 'text/csv;charset=utf-8;' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url; a.download = 'Customer List.csv';
      document.body.appendChild(a); a.click();
      document.body.removeChild(a); URL.revokeObjectURL(url);
    }

    function updateCount() {
      var el = document.getElementById('customer-count');
      el.textContent = customerRows.length
        ? customerRows.length + ' customer' + (customerRows.length !== 1 ? 's' : '') + ' in database'
        : '';
    }

    function showStatus(msg, type, persistent) {
      var el = document.getElementById('upload-status');
      var colorClass = type === 'error'
        ? 'bg-red-50 border-red-200 text-red-700'
        : type === 'info'
        ? 'bg-blue-50 border-blue-200 text-blue-700'
        : 'bg-green-50 border-green-200 text-green-700';
      el.className = 'mb-4 px-4 py-3 rounded-xl border text-sm flex items-start justify-between gap-3 ' + colorClass;
      el.innerHTML = '<span>' + msg + '</span>' +
        '<button onclick="this.closest(\'#upload-status\').classList.add(\'hidden\')" ' +
        'class="shrink-0 font-bold text-lg leading-none opacity-60 hover:opacity-100">&times;</button>';
      el.classList.remove('hidden');
      if (!persistent) setTimeout(function () { el.classList.add('hidden'); }, 6000);
    }

    function showToast(msg, type) {
      var t = document.createElement('div');
      t.textContent = msg;
      t.className = 'fixed bottom-6 right-6 z-50 px-4 py-2.5 rounded-lg text-sm font-medium shadow-lg ' +
        (type === 'warning' ? 'bg-yellow-500 text-white' : type === 'error' ? 'bg-red-500 text-white' : 'bg-green-500 text-white');
      document.body.appendChild(t);
      setTimeout(function () { t.remove(); }, 2500);
    }

    function escHtml(str) {
      return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
  </script>
</div>
</MainLayout>

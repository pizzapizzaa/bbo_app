    // ── CSV Parsing (client-side read only) ──
    function parseCSV(text) {
      var rows = [];
      var lines = text.split(/\r\n|\n|\r/);
      for (var i = 0; i < lines.length; i++) {
        if (!lines[i].trim()) continue;
        rows.push(parseCSVLine(lines[i]));
      }
      return rows;
    }

    function parseCSVLine(line) {
      var row = [], current = '', inQ = false;
      for (var i = 0; i < line.length; i++) {
        var ch = line[i];
        if (ch === '"') {
          if (inQ && line[i + 1] === '"') { current += '"'; i++; }
          else { inQ = !inQ; }
        } else if (ch === ',' && !inQ) {
          row.push(current.trim()); current = '';
        } else { current += ch; }
      }
      row.push(current.trim());
      return row;
    }

    function processCSV(text, filename) {
      // Strip UTF-8 BOM (Excel/Google Sheets often adds \uFEFF at the start)
      text = text.replace(/^\uFEFF/, '');
      var rows = parseCSV(text);
      if (rows.length < 2) {
        showStatus('The CSV file appears to be empty or has only headers.', 'error');
        return;
      }
      var headers = rows[0].map(function (h) {
        return h.replace(/^["']|["']$/g, '').trim();
      }).filter(Boolean);
      if (!headers.length) {
        showStatus('No valid column headers found in the CSV.', 'error');
        return;
      }

      var csvRows = rows.slice(1).map(function (row) {
        var obj = {};
        headers.forEach(function (h, i) { obj[h] = row[i] !== undefined ? row[i] : ''; });
        return obj;
      });

      openImportConfirmModal(csvRows, filename);
    }


---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Expenses" activePage="expenses">

  <!-- ── Row 1: Form + Stats ── -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 mb-6">

    <!-- ── Log Expense Form ── -->
    <div class="xl:col-span-1">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 h-full">
        <h2 class="font-semibold text-gray-800 mb-5">Log Expense</h2>

        <form id="expense-form" class="space-y-4" novalidate>

          <!-- Description -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              Description <span class="text-red-400">*</span>
            </label>
            <input
              id="f-desc"
              type="text"
              placeholder="e.g. Monthly electricity bill…"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
          </div>

          <!-- Expense Type -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              Expense Type <span class="text-red-400">*</span>
            </label>
            <select
              id="f-type"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            >
              <option value="">— Select type —</option>
              <option value="Construction Setup">Construction Setup</option>
              <option value="Construction Material">Construction Material</option>
              <option value="Holds">Holds</option>
              <option value="Marketing">Marketing</option>
              <option value="Rent">Rent</option>
              <option value="Utility">Utility</option>
              <option value="Manpower Cost">Manpower Cost</option>
              <option value="Misc">Misc</option>
              <option value="Operation Cost">Operation Cost</option>
              <option value="Rental Shoes">Rental Shoes</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <!-- Date -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              Date <span class="text-red-400">*</span>
            </label>
            <input
              id="f-date"
              type="date"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
          </div>

          <!-- Location -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Location</label>
            <input
              id="f-location"
              type="text"
              placeholder="e.g. BBO Gym – Main Branch"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
          </div>

          <!-- Amount -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">
              Amount (VND) <span class="text-red-400">*</span>
            </label>
            <input
              id="f-amount"
              type="number"
              min="1"
              step="1000"
              placeholder="0"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
          </div>

          <!-- Comment -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Comment</label>
            <textarea
              id="f-comment"
              rows="3"
              placeholder="Optional notes or invoice reference…"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm resize-none
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            ></textarea>
          </div>

          <!-- Form error -->
          <div id="form-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>

          <button
            type="submit"
            class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold
                   py-2.5 rounded-lg text-sm transition active:scale-[0.98] flex items-center justify-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Log Expense
          </button>
        </form>
      </div>
    </div>

    <!-- ── Stats (dark panel) ── -->
    <div class="xl:col-span-2">
      <div class="bg-gray-900 rounded-xl shadow-lg p-6 h-full flex flex-col gap-6">

        <!-- Expense stats -->
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Expenses</p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">

            <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">All Time</p>
              <p id="stat-exp-total"   class="text-xl font-bold text-red-400 tabular-nums mt-1">— ₫</p>
            </div>

            <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">This Month</p>
              <p id="lbl-month"        class="text-[10px] text-gray-500"></p>
              <p id="stat-exp-month"   class="text-xl font-bold text-red-400 tabular-nums mt-0.5">— ₫</p>
            </div>

            <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">This Quarter</p>
              <p id="lbl-quarter"      class="text-[10px] text-gray-500"></p>
              <p id="stat-exp-quarter" class="text-xl font-bold text-red-400 tabular-nums mt-0.5">— ₫</p>
            </div>

            <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">This Year</p>
              <p id="lbl-year"         class="text-[10px] text-gray-500"></p>
              <p id="stat-exp-year"    class="text-xl font-bold text-red-400 tabular-nums mt-0.5">— ₫</p>
            </div>

          </div>
        </div>

        <!-- Divider -->
        <div class="border-t border-gray-700/60"></div>

        <!-- Balance stats -->
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">
            Balance <span class="normal-case font-normal text-gray-500">(Revenue − Expenses)</span>
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">

            <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">All Time</p>
              <p id="stat-bal-total"   class="text-xl font-bold text-gray-500 tabular-nums mt-1">— ₫</p>
            </div>

            <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">This Month</p>
              <p class="text-[10px] text-gray-500" id="lbl-month-bal"></p>
              <p id="stat-bal-month"   class="text-xl font-bold text-gray-500 tabular-nums mt-0.5">— ₫</p>
            </div>

            <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">This Quarter</p>
              <p class="text-[10px] text-gray-500" id="lbl-quarter-bal"></p>
              <p id="stat-bal-quarter" class="text-xl font-bold text-gray-500 tabular-nums mt-0.5">— ₫</p>
            </div>

            <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">This Year</p>
              <p class="text-[10px] text-gray-500" id="lbl-year-bal"></p>
              <p id="stat-bal-year"    class="text-xl font-bold text-gray-500 tabular-nums mt-0.5">— ₫</p>
            </div>

          </div>
        </div>

        <!-- Divider -->
        <div class="border-t border-gray-700/60"></div>

        <!-- Monthly trend chart -->
        <div>
          <div class="flex items-center justify-between mb-3">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Monthly Trend</p>
            <!-- period toggle -->
            <div class="flex gap-1">
              <button id="chart-btn-6"  onclick="setChartMonths(6)"  class="chart-range-btn px-2.5 py-1 text-xs rounded-md bg-gray-700 text-gray-300 hover:bg-gray-600 transition">6 mo</button>
              <button id="chart-btn-12" onclick="setChartMonths(12)" class="chart-range-btn px-2.5 py-1 text-xs rounded-md bg-orange-500 text-white transition">12 mo</button>
              <button id="chart-btn-24" onclick="setChartMonths(24)" class="chart-range-btn px-2.5 py-1 text-xs rounded-md bg-gray-700 text-gray-300 hover:bg-gray-600 transition">24 mo</button>
            </div>
          </div>
          <canvas id="trend-chart" height="180"></canvas>
        </div>

      </div>
    </div>
  </div>

  <!-- ── Row 2: Full-width Expense Table ── -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h2 class="font-semibold text-gray-800 mb-5">All Expenses</h2>
    <div class="overflow-x-auto">
      <table id="expense-table" class="w-full" style="width:100%">
        <thead>
          <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Location</th>
            <th>Description</th>
            <th>Amount (VND)</th>
            <th>Comment</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

  <script is:inline>
    var expenseTable;
    var expenseData = [];
    var revenueRows = [];
    var trendChart  = null;
    var chartMonths = 12;

    var TYPE_COLORS = {
      'Construction Setup':    'bg-blue-100 text-blue-700',
      'Construction Material': 'bg-indigo-100 text-indigo-700',
      'Holds':                 'bg-purple-100 text-purple-700',
      'Marketing':             'bg-pink-100 text-pink-700',
      'Rent':                  'bg-orange-100 text-orange-700',
      'Utility':               'bg-amber-100 text-amber-700',
      'Manpower Cost':         'bg-green-100 text-green-700',
      'Misc':                  'bg-gray-100 text-gray-600',
      'Operation Cost':        'bg-sky-100 text-sky-700',
      'Rental Shoes':          'bg-teal-100 text-teal-700',
      'Other':                 'bg-slate-100 text-slate-600',
    };

    var MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

    // ── API helper ──
    function apiFetch(url, options) {
      var token = sessionStorage.getItem('bbo_token') || '';
      var headers = { 'Authorization': 'Bearer ' + token };
      if (options && options.body) headers['Content-Type'] = 'application/json';
      return fetch(url, Object.assign({}, options, { headers: headers }));
    }

    $(document).ready(function () {
      var now = new Date();

      // Date picker: default today, min = 72 months ago, max = today
      var minDate = new Date(now);
      minDate.setMonth(minDate.getMonth() - 72);
      document.getElementById('f-date').value = now.toISOString().slice(0, 10);
      document.getElementById('f-date').min   = minDate.toISOString().slice(0, 10);
      document.getElementById('f-date').max   = now.toISOString().slice(0, 10);

      // Period sub-labels
      var y = now.getFullYear();
      var m = now.getMonth();
      var q = Math.floor(m / 3) + 1;
      var periodLabel = MONTHS[m] + ' ' + y;
      var quarterLabel = 'Q' + q + ' ' + y;
      document.getElementById('lbl-month').textContent     = periodLabel;
      document.getElementById('lbl-quarter').textContent   = quarterLabel;
      document.getElementById('lbl-year').textContent      = String(y);
      document.getElementById('lbl-month-bal').textContent   = periodLabel;
      document.getElementById('lbl-quarter-bal').textContent = quarterLabel;
      document.getElementById('lbl-year-bal').textContent    = String(y);

      initTable();
      loadData();
    });

    // ── Date helpers ──
    function isoDate(d) {
      return d.getFullYear() + '-' +
             String(d.getMonth() + 1).padStart(2, '0') + '-' +
             String(d.getDate()).padStart(2, '0');
    }

    function getPeriods() {
      var now = new Date();
      var y   = now.getFullYear();
      var m   = now.getMonth();
      var qs  = Math.floor(m / 3) * 3;
      return {
        monthStart:   isoDate(new Date(y, m, 1)),
        monthEnd:     isoDate(new Date(y, m + 1, 0)),
        quarterStart: isoDate(new Date(y, qs, 1)),
        quarterEnd:   isoDate(new Date(y, qs + 3, 0)),
        yearStart:    isoDate(new Date(y, 0, 1)),
        yearEnd:      isoDate(new Date(y, 11, 31)),
      };
    }

    function sumInPeriod(rows, start, end) {
      return rows.reduce(function (acc, r) {
        var d = r.date || '';
        return (d >= start && d <= end) ? acc + (Number(r.amount) || 0) : acc;
      }, 0);
    }

    // ── Formatting ──
    function fmtVND(n) {
      return new Intl.NumberFormat('vi-VN').format(Math.round(Number(n))) + ' ₫';
    }

    function setExpStat(id, amt) {
      var el = document.getElementById(id);
      el.textContent = '- ' + fmtVND(amt);
      el.className = el.className; // keep existing
    }

    function setBalStat(id, bal) {
      var el = document.getElementById(id);
      var mt = (id === 'stat-bal-total') ? 'mt-1' : 'mt-0.5';
      if (bal >= 0) {
        el.textContent = '+ ' + fmtVND(bal);
        el.className   = 'text-xl font-bold text-emerald-400 tabular-nums ' + mt;
      } else {
        el.textContent = '- ' + fmtVND(Math.abs(bal));
        el.className   = 'text-xl font-bold text-red-400 tabular-nums ' + mt;
      }
    }

    function updateStats() {
      var p = getPeriods();

      var expTotal   = expenseData.reduce(function (a, e) { return a + (Number(e.amount) || 0); }, 0);
      var expMonth   = sumInPeriod(expenseData, p.monthStart,   p.monthEnd);
      var expQuarter = sumInPeriod(expenseData, p.quarterStart, p.quarterEnd);
      var expYear    = sumInPeriod(expenseData, p.yearStart,    p.yearEnd);

      var revTotal   = revenueRows.reduce(function (a, c) { return a + (Number(c.amount) || 0); }, 0);
      var revMonth   = sumInPeriod(revenueRows, p.monthStart,   p.monthEnd);
      var revQuarter = sumInPeriod(revenueRows, p.quarterStart, p.quarterEnd);
      var revYear    = sumInPeriod(revenueRows, p.yearStart,    p.yearEnd);

      setExpStat('stat-exp-total',   expTotal);
      setExpStat('stat-exp-month',   expMonth);
      setExpStat('stat-exp-quarter', expQuarter);
      setExpStat('stat-exp-year',    expYear);

      setBalStat('stat-bal-total',   revTotal   - expTotal);
      setBalStat('stat-bal-month',   revMonth   - expMonth);
      setBalStat('stat-bal-quarter', revQuarter - expQuarter);
      setBalStat('stat-bal-year',    revYear    - expYear);
    }

    // ── Chart helpers ──
    function buildMonthLabels(n) {
      var labels = [];
      var now    = new Date();
      for (var i = n - 1; i >= 0; i--) {
        var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
        labels.push(MONTHS[d.getMonth()] + ' ' + String(d.getFullYear()).slice(2));
      }
      return labels;
    }

    function buildMonthKeys(n) {
      var keys = [];
      var now  = new Date();
      for (var i = n - 1; i >= 0; i--) {
        var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
        keys.push(d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0'));
      }
      return keys;
    }

    function sumByMonth(rows, keys) {
      var map = {};
      keys.forEach(function (k) { map[k] = 0; });
      rows.forEach(function (r) {
        var k = (r.date || '').slice(0, 7);
        if (map[k] !== undefined) map[k] += (Number(r.amount) || 0);
      });
      return keys.map(function (k) { return map[k]; });
    }

    function setChartMonths(n) {
      chartMonths = n;
      // update button styles
      [6, 12, 24].forEach(function (v) {
        var btn = document.getElementById('chart-btn-' + v);
        if (v === n) {
          btn.className = 'chart-range-btn px-2.5 py-1 text-xs rounded-md bg-orange-500 text-white transition';
        } else {
          btn.className = 'chart-range-btn px-2.5 py-1 text-xs rounded-md bg-gray-700 text-gray-300 hover:bg-gray-600 transition';
        }
      });
      renderChart();
    }

    function renderChart() {
      var keys   = buildMonthKeys(chartMonths);
      var labels = buildMonthLabels(chartMonths);
      var expVals = sumByMonth(expenseData, keys);
      var revVals = sumByMonth(revenueRows, keys);
      var balVals = revVals.map(function (r, i) { return r - expVals[i]; });

      var ctx = document.getElementById('trend-chart').getContext('2d');

      if (trendChart) {
        trendChart.data.labels             = labels;
        trendChart.data.datasets[0].data   = expVals;
        trendChart.data.datasets[1].data   = revVals;
        trendChart.data.datasets[2].data   = balVals;
        trendChart.update();
        return;
      }

      trendChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Expenses',
              data: expVals,
              borderColor:     'rgb(248, 113, 113)',
              backgroundColor: 'rgba(248, 113, 113, 0.08)',
              pointBackgroundColor: 'rgb(248, 113, 113)',
              tension: 0.35,
              fill: false,
              pointRadius: 4,
              pointHoverRadius: 6,
            },
            {
              label: 'Revenue',
              data: revVals,
              borderColor:     'rgb(251, 146, 60)',
              backgroundColor: 'rgba(251, 146, 60, 0.08)',
              pointBackgroundColor: 'rgb(251, 146, 60)',
              tension: 0.35,
              fill: false,
              pointRadius: 4,
              pointHoverRadius: 6,
            },
            {
              label: 'Balance',
              data: balVals,
              borderColor:     'rgb(52, 211, 153)',
              backgroundColor: 'rgba(52, 211, 153, 0.08)',
              pointBackgroundColor: 'rgb(52, 211, 153)',
              tension: 0.35,
              fill: false,
              pointRadius: 4,
              pointHoverRadius: 6,
              borderDash: [5, 3],
            }
          ]
        },
        options: {
          responsive: true,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              display: true,
              position: 'bottom',
              labels: {
                color: '#9ca3af',
                boxWidth: 12,
                boxHeight: 12,
                borderRadius: 3,
                useBorderRadius: true,
                padding: 18,
                font: { size: 11, family: 'Inter, system-ui, sans-serif' },
              }
            },
            tooltip: {
              backgroundColor: '#1f2937',
              titleColor: '#f3f4f6',
              bodyColor: '#d1d5db',
              borderColor: '#374151',
              borderWidth: 1,
              padding: 10,
              callbacks: {
                label: function (ctx) {
                  var val = ctx.parsed.y;
                  var abs = Math.abs(val);
                  var formatted = new Intl.NumberFormat('vi-VN').format(Math.round(abs)) + ' ₫';
                  return ' ' + ctx.dataset.label + ': ' + (val < 0 ? '- ' : '') + formatted;
                }
              }
            }
          },
          scales: {
            x: {
              grid:  { color: 'rgba(255,255,255,0.05)' },
              ticks: { color: '#6b7280', font: { size: 10 } },
              border: { color: 'rgba(255,255,255,0.08)' }
            },
            y: {
              grid:  { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                color: '#6b7280',
                font: { size: 10 },
                stepSize: 10000000,
                callback: function (v) {
                  var abs = Math.abs(v);
                  var sign = v < 0 ? '-' : '';
                  if (abs >= 1000000000) return sign + (abs / 1000000000).toFixed(1).replace(/\.0$/, '') + 'B';
                  if (abs >= 1000000)    return sign + (abs / 1000000).toFixed(0) + 'M';
                  if (abs >= 1000)       return sign + (abs / 1000).toFixed(0) + 'K';
                  return v;
                }
              },
              border: { color: 'rgba(255,255,255,0.08)' }
            }
          }
        }
      });
    }

    function loadData() {
      apiFetch('/api/expenses')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          expenseData = data.expenses     || [];
          revenueRows = data.revenue_rows || [];
          refreshTable(expenseData);
          updateStats();
          renderChart();
        })
        .catch(function (err) { showToast('Failed to load data: ' + err.message, 'error'); });
    }

    function initTable() {
      expenseTable = $('#expense-table').DataTable({
        data: [],
        columns: [
          { title: 'Date' },
          { title: 'Type' },
          { title: 'Location' },
          { title: 'Description' },
          { title: 'Amount (VND)', className: 'dt-right' },
          { title: 'Comment' },
          { title: 'Actions', orderable: false, searchable: false }
        ],
        dom: "<'flex flex-wrap items-center justify-between gap-3 mb-3'<'flex gap-2'B><'flex-1 text-right'f>>" +
             "t" +
             "<'flex flex-wrap items-center justify-between mt-3'<'text-sm text-gray-500'i><'flex gap-1'p>>",
        buttons: [{
          extend: 'csvHtml5',
          text: '⬇ Export CSV',
          title: 'Expenses',
          className: 'dt-btn-custom',
          exportOptions: { columns: [0, 1, 2, 3, 4, 5] }
        }],
        order: [[0, 'desc']],
        pageLength: 15,
        language: { emptyTable: 'No expenses logged yet. Add one using the form.' }
      });
    }

    var COMMENT_LINES = 3; // lines to show before truncating
    var LINE_HEIGHT_EM = 1.5;

    function commentCell(text) {
      if (!text) return '';
      var safe = escHtml(text);
      // Heuristic: only add toggle if text is likely > 3 lines (> ~150 chars or contains newlines)
      var lineCount = (text.match(/\n/g) || []).length + 1;
      var needsToggle = text.length > 150 || lineCount > COMMENT_LINES;
      if (!needsToggle) return '<span class="whitespace-pre-wrap text-sm">' + safe + '</span>';
      return '<div class="comment-cell" style="max-height:' + (COMMENT_LINES * LINE_HEIGHT_EM) + 'em;' +
             'overflow:hidden;line-height:' + LINE_HEIGHT_EM + 'em;transition:max-height 0.2s ease">' +
             '<span class="whitespace-pre-wrap text-sm">' + safe + '</span>' +
             '</div>' +
             '<button class="comment-toggle text-xs text-orange-500 hover:text-orange-700 font-medium mt-0.5"' +
             ' data-expanded="false">Read More</button>';
    }

    // Event delegation — works after every DataTable draw
    $(document).on('click', '.comment-toggle', function () {
      var btn  = $(this);
      var cell = btn.prev('.comment-cell');
      var expanded = btn.attr('data-expanded') === 'true';
      if (expanded) {
        cell.css('max-height', (COMMENT_LINES * LINE_HEIGHT_EM) + 'em');
        btn.text('Read More').attr('data-expanded', 'false');
      } else {
        // expand to full natural height
        cell.css('max-height', cell[0].scrollHeight + 'px');
        btn.text('Hide').attr('data-expanded', 'true');
      }
    });

    function typeBadge(type) {
      var cls = TYPE_COLORS[type] || 'bg-gray-100 text-gray-600';
      return '<span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium whitespace-nowrap ' +
             cls + '">' + escHtml(type) + '</span>';
    }

    function buildRows(data) {
      return data.map(function (e) {
        var safeId = escHtml(String(e.id));
        return [
          e.date || '',
          typeBadge(e.type || ''),
          escHtml(e.location || ''),
          escHtml(e.description || ''),
          '<span class="font-medium text-red-500 whitespace-nowrap">- ' + fmtVND(e.amount) + '</span>',
          commentCell(e.comment || ''),
          '<button onclick="deleteExpense(\'' + safeId + '\')" ' +
            'class="inline-flex items-center gap-1 text-xs text-red-500 hover:text-red-700 ' +
            'hover:bg-red-50 px-2 py-1 rounded transition">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" ' +
            'd="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>' +
            '</svg>Delete</button>'
        ];
      });
    }

    function refreshTable(data) {
      expenseTable.clear();
      expenseTable.rows.add(buildRows(data));
      expenseTable.draw();
    }

    var SUBMIT_BTN_HTML =
      '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
      '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>' +
      ' Log Expense';

    document.getElementById('expense-form').addEventListener('submit', function (e) {
      e.preventDefault();
      var errEl = document.getElementById('form-error');
      errEl.classList.add('hidden');

      var desc     = document.getElementById('f-desc').value.trim();
      var type     = document.getElementById('f-type').value;
      var date     = document.getElementById('f-date').value;
      var location = document.getElementById('f-location').value.trim();
      var amount   = Number(document.getElementById('f-amount').value);
      var comment  = document.getElementById('f-comment').value.trim();

      if (!desc || !type || !date) {
        errEl.textContent = 'Please fill in Description, Type, and Date.';
        errEl.classList.remove('hidden');
        return;
      }
      if (!amount || amount <= 0) {
        errEl.textContent = 'Please enter a valid Amount greater than 0.';
        errEl.classList.remove('hidden');
        return;
      }

      var btn = e.target.querySelector('[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Saving…';

      apiFetch('/api/expenses', {
        method: 'POST',
        body: JSON.stringify({ description: desc, type: type, date: date, location: location, amount: amount, comment: comment })
      })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          btn.disabled = false;
          btn.innerHTML = SUBMIT_BTN_HTML;
          if (data.error) { errEl.textContent = data.error; errEl.classList.remove('hidden'); return; }
          expenseData.unshift(data.expense);
          refreshTable(expenseData);
          updateStats();
          document.getElementById('f-desc').value     = '';
          document.getElementById('f-type').value     = '';
          document.getElementById('f-location').value = '';
          document.getElementById('f-amount').value   = '';
          document.getElementById('f-comment').value  = '';
          showToast('Expense logged!');
        })
        .catch(function (err) {
          btn.disabled = false;
          btn.innerHTML = SUBMIT_BTN_HTML;
          errEl.textContent = 'Save failed: ' + err.message;
          errEl.classList.remove('hidden');
        });
    });

    function deleteExpense(id) {
      if (!confirm('Delete this expense entry?')) return;
      apiFetch('/api/expenses/' + id, { method: 'DELETE' })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.error) { showToast('Delete failed: ' + data.error, 'error'); return; }
          expenseData = expenseData.filter(function (e) { return String(e.id) !== String(id); });
          refreshTable(expenseData);
          updateStats();
          showToast('Expense deleted.', 'warning');
        })
        .catch(function (err) { showToast('Delete failed: ' + err.message, 'error'); });
    }

    function escHtml(str) {
      return String(str || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function showToast(msg, type) {
      var t = document.createElement('div');
      t.textContent = msg;
      t.className = 'fixed bottom-6 right-6 z-50 px-4 py-2.5 rounded-lg text-sm font-medium shadow-lg ' +
        (type === 'warning' ? 'bg-yellow-500 text-white' : type === 'error' ? 'bg-red-500 text-white' : 'bg-green-500 text-white');
      document.body.appendChild(t);
      setTimeout(function () { t.remove(); }, 2500);
    }
  </script>

</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Dashboard" activePage="dashboard">

  <!-- Stat cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 mb-8">

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
      <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
        <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm text-gray-500">Total Customers</p>
        <p id="stat-customers" class="text-2xl font-bold text-gray-900">—</p>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
      <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center shrink-0">
        <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
        </svg>
      </div>
      <div>
        <p class="text-sm text-gray-500">Today's Check-ins</p>
        <p id="stat-checkins" class="text-2xl font-bold text-gray-900">—</p>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
      <div class="w-12 h-12 rounded-xl bg-orange-50 flex items-center justify-center shrink-0">
        <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm text-gray-500">Today's Revenue</p>
        <p id="stat-revenue" class="text-2xl font-bold text-gray-900">—</p>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
      <div class="w-12 h-12 rounded-xl bg-purple-50 flex items-center justify-center shrink-0">
        <svg class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm text-gray-500">Staff on Duty Today</p>
        <p id="stat-staff" class="text-2xl font-bold text-gray-900">—</p>
      </div>
    </div>
  </div>

  <!-- Call to actions -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <a href="/checkin"
       class="flex items-center gap-4 bg-orange-500 hover:bg-orange-600 text-white rounded-xl p-5 shadow-sm transition-colors">
      <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center shrink-0">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
        </svg>
      </div>
      <div>
        <p class="text-lg font-semibold">Check-in Customers</p>
        <p class="text-sm text-orange-100">Record a new customer visit</p>
      </div>
    </a>

    <a href="/expenses"
       class="flex items-center gap-4 bg-blue-500 hover:bg-blue-600 text-white rounded-xl p-5 shadow-sm transition-colors">
      <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center shrink-0">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-lg font-semibold">Log Expenses</p>
        <p class="text-sm text-blue-100">Record a new business expense</p>
      </div>
    </a>
  </div>

  <!-- Two-column bottom -->
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">

    <!-- Recent check-ins -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-gray-800">Recent Check-ins Today</h2>
        <a href="/checkin" class="text-sm text-orange-500 hover:text-orange-600 font-medium">View all →</a>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left py-2 px-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Time</th>
              <th class="text-left py-2 px-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Customer</th>
              <th class="text-left py-2 px-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Payment</th>
              <th class="text-right py-2 px-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
            </tr>
          </thead>
          <tbody id="recent-checkins">
            <tr><td colspan="4" class="py-8 text-center text-gray-400 text-sm">No check-ins today yet.</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Today's schedule -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-gray-800">Today's Staff Schedule</h2>
        <a href="/schedule" class="text-sm text-orange-500 hover:text-orange-600 font-medium">Manage →</a>
      </div>
      <div id="today-schedule">
        <p class="py-8 text-center text-gray-400 text-sm">No staff scheduled today.</p>
      </div>
    </div>

  </div>

  <script is:inline>
    $(document).ready(function () {
      var today = new Date().toISOString().slice(0, 10);

      // Load all three in parallel
      Promise.all([
        apiFetch('/api/customers').then(function (r) { return r.json(); }).catch(function () { return {}; }),
        apiFetch('/api/checkins?date=' + today).then(function (r) { return r.json(); }).catch(function () { return {}; }),
        apiFetch('/api/schedule').then(function (r) { return r.json(); }).catch(function () { return {}; })
      ]).then(function (results) {
        var custData  = results[0];
        var ciData    = results[1];
        var schedData = results[2];

        // ── Customers stat ──
        var totalCustomers = custData.total != null ? custData.total : (custData.rows || []).length;
        document.getElementById('stat-customers').textContent = totalCustomers;

        // ── Check-ins ──
        var todayCI = ciData.checkins || [];
        document.getElementById('stat-checkins').textContent = todayCI.length;
        var revenue = todayCI.reduce(function (s, c) { return s + (parseFloat(c.amount) || 0); }, 0);
        document.getElementById('stat-revenue').textContent = Math.round(revenue).toLocaleString('vi-VN') + ' ₫';

        // ── Recent check-ins table ──
        var recent = todayCI.slice(-8).reverse();
        var tbody  = document.getElementById('recent-checkins');
        if (recent.length) {
          tbody.innerHTML = recent.map(function (c) {
            return '<tr class="border-b border-gray-50 last:border-0">' +
              '<td class="py-2.5 px-1 text-gray-600">' + (c.time || '').slice(0, 5) + '</td>' +
              '<td class="py-2.5 px-1 font-medium text-gray-800">' + escHtml(c.customer_name) + '</td>' +
              '<td class="py-2.5 px-1"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ' +
                payBadge(c.payment_method) + '">' + escHtml(c.payment_method) + '</span></td>' +
              '<td class="py-2.5 px-1 text-right text-gray-700">' +
                (c.amount ? Math.round(parseFloat(c.amount)).toLocaleString('vi-VN') + ' ₫' : '—') + '</td>' +
            '</tr>';
          }).join('');
        }

        // ── Schedule ──
        var allEntries  = schedData.entries || [];
        var todaySched  = allEntries.filter(function (s) { return s.date === today; });
        document.getElementById('stat-staff').textContent = todaySched.length;

        var schedDiv = document.getElementById('today-schedule');
        if (todaySched.length) {
          schedDiv.innerHTML = todaySched.map(function (s) {
            var initial = (s.staff_name || '?').charAt(0).toUpperCase();
            return '<div class="flex items-center justify-between py-2.5 border-b border-gray-50 last:border-0">' +
              '<div class="flex items-center gap-3">' +
                '<div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center ' +
                     'text-purple-600 text-xs font-bold shrink-0">' + initial + '</div>' +
                '<span class="text-sm font-medium text-gray-800">' + escHtml(s.staff_name) + '</span>' +
              '</div>' +
              '<div class="text-sm text-gray-500">' + escHtml(s.start_time) + ' – ' + escHtml(s.end_time) + '</div>' +
            '</div>';
          }).join('');
        }
      });

      function escHtml(str) {
        return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }
      function payBadge(pm) {
        return { 'Cash': 'bg-green-100 text-green-700', 'Card': 'bg-blue-100 text-blue-700',
                 'Digital Wallet': 'bg-indigo-100 text-indigo-700', 'Complimentary': 'bg-gray-100 text-gray-600' }[pm]
               || 'bg-gray-100 text-gray-600';
      }
    });
  </script>
</MainLayout>

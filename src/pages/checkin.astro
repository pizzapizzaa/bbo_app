---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Daily Check-in" activePage="checkin">

  <!-- Daily stats + Date selector -->
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">

    <!-- Daily stats (left — aligned with check-in card) -->
    <div class="flex items-center gap-4">
      <div class="text-center">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Check-ins</p>
        <p id="stat-count" class="text-2xl font-bold text-gray-900">0</p>
      </div>
      <div class="w-px h-10 bg-gray-200"></div>
      <div class="text-center">
        <p class="text-xs text-gray-500 uppercase tracking-wide">Revenue</p>
        <p id="stat-rev" class="text-2xl font-bold text-orange-500">0 ₫</p>
      </div>
    </div>

    <!-- Date range selector (right — aligned with check-in list) -->
    <div class="flex flex-wrap items-center gap-2">
      <label class="text-sm font-medium text-gray-600">From:</label>
      <input
        id="view-from"
        type="date"
        class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm
               focus:outline-none focus:ring-2 focus:ring-orange-400"
      />
      <label class="text-sm font-medium text-gray-600">To:</label>
      <input
        id="view-to"
        type="date"
        class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm
               focus:outline-none focus:ring-2 focus:ring-orange-400"
      />
      <button onclick="refreshForRange()"
              class="px-3 py-1.5 bg-orange-500 hover:bg-orange-600 text-white
                     rounded-lg text-sm font-medium transition">
        Go
      </button>
      <div class="w-px h-6 bg-gray-200"></div>
      <button onclick="setQuick('today')"
              class="px-2.5 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600
                     rounded-lg text-xs font-medium transition">
        Today
      </button>
      <button onclick="setQuick('week')"
              class="px-2.5 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600
                     rounded-lg text-xs font-medium transition">
        This Week
      </button>
      <button onclick="setQuick('month')"
              class="px-2.5 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600
                     rounded-lg text-xs font-medium transition">
        This Month
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- ── Check-in Form ── -->
    <div class="xl:col-span-1">
      <div class="bg-gray-900 rounded-xl shadow-lg p-6">
        <h2 class="font-semibold text-white mb-5 tracking-wide">New Check-in</h2>

        <form id="checkin-form" class="space-y-4" novalidate>

          <!-- Customer search -->
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">
              Customer <span class="text-red-400">*</span>
            </label>
            <input
              id="f-customer"
              list="customer-datalist"
              type="text"
              placeholder="Type to search customer…"
              autocomplete="off"
              class="w-full bg-gray-800 border border-gray-600 text-white placeholder-gray-500 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
            <datalist id="customer-datalist"></datalist>
            <p id="customer-hint" class="text-xs text-gray-500 mt-1">
              Load customers on the <a href="/customers" class="text-orange-400 hover:underline">Customers</a> page first.
            </p>
          </div>

          <!-- Check-in Date + Time -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">
                Date <span class="text-red-400">*</span>
              </label>
              <input
                id="f-checkin-date"
                type="date"
                class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">
                Time <span class="text-red-400">*</span>
              </label>
              <input
                id="f-checkin-time"
                type="time"
                class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
              />
            </div>
          </div>

          <!-- Check-in Type -->
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Check-in Type</label>
            <select
              id="f-checkin-type"
              class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            >
              <option value="" data-price="0">— Select type —</option>
              <optgroup label="Day Pass">
                <option value="Day Pass – Adult" data-price="160000">Day Pass – Adult (160,000 ₫)</option>
                <option value="Day Pass – Student" data-price="120000">Day Pass – Student (120,000 ₫)</option>
                <option value="Day Pass – Kid" data-price="100000">Day Pass – Kid (100,000 ₫)</option>
              </optgroup>
              <optgroup label="10 Punches">
                <option value="10 Punches – Adult" data-price="1400000">10 Punches – Adult (1,400,000 ₫)</option>
                <option value="10 Punches – Student" data-price="1000000">10 Punches – Student (1,000,000 ₫)</option>
                <option value="10 Punches – Kid" data-price="800000">10 Punches – Kid (800,000 ₫)</option>
              </optgroup>
              <optgroup label="20 Punches">
                <option value="20 Punches – Adult" data-price="2500000">20 Punches – Adult (2,500,000 ₫)</option>
              </optgroup>
              <optgroup label="PT Punches">
                <option value="10 PT Punches – Shingo PT" data-price="0">10 PT Punches – Shingo PT</option>
                <option value="10 PT Punches – Other PT" data-price="0">10 PT Punches – Other PT</option>
              </optgroup>
              <optgroup label="Membership">
                <option value="Membership – 1 Month" data-price="1250000">Membership – 1 Month (1,250,000 ₫)</option>
                <option value="Membership – 3 Months" data-price="3050000">Membership – 3 Months (3,050,000 ₫)</option>
                <option value="Membership – 6 Months" data-price="5650000">Membership – 6 Months (5,650,000 ₫)</option>
                <option value="Membership – 12 Months" data-price="9850000">Membership – 12 Months (9,850,000 ₫)</option>
              </optgroup>
            </select>
          </div>

          <!-- Add-ons (collapsible) -->
          <div>
            <button type="button" onclick="toggleAddons()"
                    class="w-full flex items-center justify-between text-sm font-medium text-gray-300 mb-1.5 focus:outline-none">
              <span>Add-ons</span>
              <svg id="addons-chevron" class="w-4 h-4 transition-transform duration-200"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div id="addons-body" class="hidden">
              <div class="grid grid-cols-2 gap-y-2 gap-x-3 bg-gray-800 border border-gray-600 rounded-lg px-3 py-2.5">
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="checkbox" class="addon-cb accent-orange-500 w-4 h-4 cursor-pointer" data-name="Chalk Ball" data-price="75000" />
                  <span>Chalk Ball <span class="text-gray-500 text-xs">75,000 ₫</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="checkbox" class="addon-cb accent-orange-500 w-4 h-4 cursor-pointer" data-name="Liquid Chalk Rental" data-price="25000" />
                  <span>Liquid Chalk Rental <span class="text-gray-500 text-xs">25,000 ₫</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="checkbox" class="addon-cb accent-orange-500 w-4 h-4 cursor-pointer" data-name="Shoes Rental" data-price="20000" />
                  <span>Shoes Rental <span class="text-gray-500 text-xs">20,000 ₫</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="checkbox" class="addon-cb accent-orange-500 w-4 h-4 cursor-pointer" data-name="Vitani Dasani" data-price="8000" />
                  <span>Vitani Dasani <span class="text-gray-500 text-xs">8,000 ₫</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="checkbox" class="addon-cb accent-orange-500 w-4 h-4 cursor-pointer" data-name="Ionlife" data-price="10000" />
                  <span>Ionlife <span class="text-gray-500 text-xs">10,000 ₫</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="checkbox" class="addon-cb accent-orange-500 w-4 h-4 cursor-pointer" data-name="Pocari" data-price="18000" />
                  <span>Pocari <span class="text-gray-500 text-xs">18,000 ₫</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="checkbox" class="addon-cb accent-orange-500 w-4 h-4 cursor-pointer" data-name="Liquid Chalk Small" data-price="70000" />
                  <span>Liquid Chalk Small <span class="text-gray-500 text-xs">70,000 ₫</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="checkbox" class="addon-cb accent-orange-500 w-4 h-4 cursor-pointer" data-name="Liquid Chalk Big" data-price="150000" />
                  <span>Liquid Chalk Big <span class="text-gray-500 text-xs">150,000 ₫</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="checkbox" class="addon-cb accent-orange-500 w-4 h-4 cursor-pointer" data-name="Socks" data-price="10000" />
                  <span>Socks <span class="text-gray-500 text-xs">10,000 ₫</span></span>
                </label>
              </div>
            </div>
          </div>

          <!-- Discount (collapsible) -->
          <div>
            <button type="button" onclick="toggleDiscount()"
                    class="w-full flex items-center justify-between text-sm font-medium text-gray-300 mb-1.5 focus:outline-none">
              <span>Discount</span>
              <svg id="discount-chevron" class="w-4 h-4 transition-transform duration-200"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div id="discount-body" class="hidden">
              <div class="bg-gray-800 border border-gray-600 rounded-lg px-3 py-2.5 space-y-2">
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="radio" name="discount" class="discount-rb accent-orange-500 w-4 h-4 cursor-pointer" value="" checked />
                  <span class="text-gray-400">No discount</span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="radio" name="discount" class="discount-rb accent-orange-500 w-4 h-4 cursor-pointer" value="day30" />
                  <span>30% discount <span class="text-gray-500 text-xs">Day Pass – setting day (less disturbance)</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="radio" name="discount" class="discount-rb accent-orange-500 w-4 h-4 cursor-pointer" value="day40" />
                  <span>40% discount <span class="text-gray-500 text-xs">Day Pass – setting day (more disturbance)</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="radio" name="discount" class="discount-rb accent-orange-500 w-4 h-4 cursor-pointer" value="lasthour50" />
                  <span>50% discount <span class="text-gray-500 text-xs">Day Pass (late entry)</span></span>
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                  <input type="radio" name="discount" class="discount-rb accent-orange-500 w-4 h-4 cursor-pointer" value="birthday" />
                  <span>Birthday discount <span class="text-gray-500 text-xs">Free shoes or 20,000 ₫ off</span></span>
                </label>
              </div>
            </div>
          </div>

          <!-- Payment method -->
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">
              Payment Method <span class="text-red-400">*</span>
            </label>
            <select
              id="f-payment"
              class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            >
              <option value="">— Select —</option>
              <option value="Cash">Cash</option>
              <option value="Local Card">Local Card</option>
              <option value="International Card">International Card</option>
              <option value="Local Bank Transfer">Local Bank Transfer</option>
              <option value="Complimentary">Complimentary</option>
              <option value="Punch Card">Punch Card</option>
              <option value="PT Punch">PT Punch</option>
              <option value="Valid Membership">Valid Membership</option>
            </select>
          </div>

          <!-- Use punch from (shown only when Punch Card is selected) -->
          <div id="punch-from-row" class="hidden">
            <label class="block text-sm font-medium text-gray-300 mb-1.5">
              Use punch from <span class="text-red-400">*</span>
            </label>
            <select
              id="f-punch-from"
              class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            >
              <option value="">— Select punch card holder —</option>
            </select>
            <p id="punch-from-hint" class="hidden text-xs text-yellow-400 mt-1">No punch card holders with remaining punches found.</p>
          </div>

          <!-- Use PT punch from (shown only when PT Punch is selected) -->
          <div id="pt-punch-from-row" class="hidden">
            <label class="block text-sm font-medium text-gray-300 mb-1.5">
              Use PT punch from <span class="text-red-400">*</span>
            </label>
            <select
              id="f-pt-punch-from"
              class="w-full bg-gray-800 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent"
            >
              <option value="">— Select PT punch holder —</option>
            </select>
            <p id="pt-punch-from-hint" class="hidden text-xs text-yellow-400 mt-1">No customers with remaining PT punches found.</p>
          </div>

          <!-- Amount -->
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">
              Amount (VND) <span class="text-gray-500 text-xs font-normal">— auto-calculated</span>
            </label>
            <input
              id="f-amount"
              type="number"
              min="0"
              step="0.01"
              placeholder="0.00"
              class="w-full bg-gray-800 border border-gray-600 text-white placeholder-gray-500 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
          </div>

          <!-- Notes -->
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Notes</label>
            <input
              id="f-notes"
              type="text"
              placeholder="Optional…"
              class="w-full bg-gray-800 border border-gray-600 text-white placeholder-gray-500 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
          </div>

          <!-- Check-in timestamp preview -->
          <div class="text-xs text-gray-400 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2">
            Timestamp: <span id="ts-preview" class="font-medium text-gray-200"></span>
          </div>

          <!-- Error -->
          <div id="form-error" class="hidden text-sm text-red-400 bg-red-900/40 border border-red-700 rounded-lg px-3 py-2"></div>

          <button
            type="submit"
            class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold
                   py-3 rounded-lg text-sm transition active:scale-[0.98] flex items-center justify-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Record Check-in
          </button>
        </form>
      </div>
    </div>

    <!-- ── Check-ins Table ── -->
    <div class="xl:col-span-2">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center justify-between mb-5">
          <h2 class="font-semibold text-gray-800">
            Check-ins: <span id="table-date-label" class="text-orange-500"></span>
          </h2>
          <button onclick="exportCheckins()"
                  class="inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-gray-800
                         bg-gray-50 hover:bg-gray-100 border border-gray-200 px-3 py-1.5 rounded-lg transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Export CSV
          </button>
        </div>

        <!-- Loading spinner -->
        <div id="checkin-loading" class="hidden py-16 flex flex-col items-center justify-center gap-3">
          <div class="w-10 h-10 border-4 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
          <p class="text-sm text-gray-400">Loading check-ins…</p>
        </div>

        <div id="checkin-table-wrap" class="overflow-x-auto">
          <table id="checkin-table" class="w-full" style="width:100%">
            <thead>
              <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Customer</th>
                <th>Type</th>
                <th>Payment</th>
                <th>Amount (VND)</th>
                <th>Add-ons</th>
                <th>Punch From</th>
                <th>PT Punch From</th>
                <th>Notes</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    var checkinTable;
    var allCheckins  = [];
    var activeFrom   = '';
    var activeTo     = '';
    var allCustomers = [];  // cache with punch card info

    // ── API helper ──
    function apiFetch(url, options) {
      var token = localStorage.getItem('bbo_token') || '';
      var headers = { 'Authorization': 'Bearer ' + token };
      if (options && options.body) headers['Content-Type'] = 'application/json';
      return fetch(url, Object.assign({}, options, { headers: headers }));
    }

    $(document).ready(function () {
      var now   = new Date();
      var today = now.toISOString().slice(0, 10);
      var timeNow = now.toTimeString().slice(0, 5);

      document.getElementById('view-from').value             = today;
      document.getElementById('view-to').value               = today;
      document.getElementById('table-date-label').textContent = formatDateLabel(today);
      document.getElementById('f-checkin-date').value         = today;
      document.getElementById('f-checkin-time').value         = timeNow;
      activeFrom = today;
      activeTo   = today;

      updateTsPreview();
      $('#f-checkin-date, #f-checkin-time').on('change', updateTsPreview);

      buildCustomerDatalist();
      initTable();
      loadCheckinsForRange(today, today);
    });

    function updateTsPreview() {
      var d = document.getElementById('f-checkin-date').value;
      var t = document.getElementById('f-checkin-time').value;
      var el = document.getElementById('ts-preview');
      if (el && d && t) {
        el.textContent = new Date(d + 'T' + t).toLocaleString('en-MY', {
          year: 'numeric', month: 'short', day: 'numeric',
          hour: '2-digit', minute: '2-digit'
        });
      }
    }

    function buildCustomerDatalist() {
      apiFetch('/api/customers')
        .then(function (res) { return res.json(); })
        .then(function (data) {
          var rows = data.rows || [];
          allCustomers = rows;
          var list = document.getElementById('customer-datalist');
          list.innerHTML = '';
          // Always prepend fixed entries
          ['New Customer', 'Other'].forEach(function (label) {
            var opt = document.createElement('option');
            opt.value = label;
            list.appendChild(opt);
          });
          if (rows.length) {
            document.getElementById('customer-hint').classList.add('hidden');
            rows.forEach(function (c) {
              var opt = document.createElement('option');
              opt.value = c['Full Name'] || '';
              list.appendChild(opt);
            });
          }
          buildPunchCardDropdown(rows);
          buildPTPunchDropdown(rows);
        })
        .catch(function () { /* datalist is optional — ignore errors */ });
    }

    function buildPunchCardDropdown(customers) {
      var select = document.getElementById('f-punch-from');
      var hint   = document.getElementById('punch-from-hint');
      // Keep placeholder, rebuild the rest
      select.innerHTML = '<option value="">— Select punch card holder —</option>';
      var holders = (customers || allCustomers).filter(function (c) {
        return c._is_punch_card_holder && c._punches_remaining > 0;
      });
      holders.forEach(function (c) {
        var opt = document.createElement('option');
        opt.value            = c._id;
        opt.dataset.holderName = c['Full Name'] || '';
        opt.textContent      = (c['Full Name'] || '') + ' (' + c._punches_remaining + ' punch' + (c._punches_remaining !== 1 ? 'es' : '') + ' left)';
        select.appendChild(opt);
      });
      hint.classList.toggle('hidden', holders.length > 0);
    }

    function buildPTPunchDropdown(customers) {
      var select = document.getElementById('f-pt-punch-from');
      var hint   = document.getElementById('pt-punch-from-hint');
      select.innerHTML = '<option value="">— Select PT punch holder —</option>';
      var holders = (customers || allCustomers).filter(function (c) {
        return c._pt_punches_remaining > 0;
      });
      holders.forEach(function (c) {
        var opt = document.createElement('option');
        opt.value              = c._id;
        opt.dataset.holderName = c['Full Name'] || '';
        opt.textContent        = (c['Full Name'] || '') + ' (' + c._pt_punches_remaining + ' PT punch' + (c._pt_punches_remaining !== 1 ? 'es' : '') + ' left)';
        select.appendChild(opt);
      });
      hint.classList.toggle('hidden', holders.length > 0);
    }

    function loadCheckinsForRange(from, to) {
      var qs = (from === to)
        ? '?date=' + from
        : '?from=' + from + '&to=' + to;
      document.getElementById('checkin-loading').classList.remove('hidden');
      document.getElementById('checkin-table-wrap').classList.add('hidden');
      apiFetch('/api/checkins' + qs)
        .then(function (res) { return res.json(); })
        .then(function (data) {
          document.getElementById('checkin-loading').classList.add('hidden');
          document.getElementById('checkin-table-wrap').classList.remove('hidden');
          allCheckins = data.checkins || [];
          renderTable(allCheckins);
          updateStats(allCheckins);
        })
        .catch(function (err) {
          document.getElementById('checkin-loading').classList.add('hidden');
          document.getElementById('checkin-table-wrap').classList.remove('hidden');
          showToast('Failed to load check-ins: ' + err.message, 'error');
        });
    }

    function initTable() {
      checkinTable = $('#checkin-table').DataTable({
        data: [],
        columns: [
          { title: 'Date' },
          { title: 'Time' },
          { title: 'Customer' },
          { title: 'Type' },
          { title: 'Payment' },
          { title: 'Amount (VND)' },
          { title: 'Add-ons' },
          { title: 'Punch From' },
          { title: 'PT Punch From' },
          { title: 'Notes' },
          { title: 'Actions', orderable: false, searchable: false }
        ],
        dom: "<'flex flex-wrap items-center justify-between gap-3 mb-3'<'text-sm text-gray-500'i><'flex-1 text-right'f>>" +
             "t" +
             "<'flex flex-wrap items-center justify-between mt-3'<''><'flex gap-1'p>>",
        order: [[0, 'asc'], [1, 'asc']],
        pageLength: 20,
        language: { emptyTable: 'No check-ins for this period.' }
      });
    }

    function buildRows(checkins) {
      return checkins.map(function (c) {
        return [
          c.date || '',
          (c.time || '').slice(0, 5),
          escHtml(c.customer_name || ''),
          c.checkin_type
            ? '<span class="text-xs font-medium text-gray-700">' + escHtml(c.checkin_type) + '</span>'
            : '<span class="text-gray-300">—</span>',
          '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ' +
            payBadge(c.payment_method) + '">' + escHtml(c.payment_method) + '</span>',
          c.amount ? Math.round(parseFloat(c.amount)).toLocaleString('vi-VN') + ' ₫' : '—',
          c.addons
            ? '<span class="text-xs text-gray-600">' + escHtml(c.addons) + '</span>'
            : '<span class="text-gray-300">—</span>',
          c.punch_card_holder_name
            ? '<span class="text-xs text-purple-600 font-medium">' + escHtml(c.punch_card_holder_name) + '</span>'
            : '<span class="text-gray-300">—</span>',
          c.pt_punch_holder_name
            ? '<span class="text-xs text-indigo-600 font-medium">' + escHtml(c.pt_punch_holder_name) + '</span>'
            : '<span class="text-gray-300">—</span>',
          escHtml(c.notes || ''),
          '<button onclick="deleteCheckin(\'' + c.id + '\')" ' +
            'class="inline-flex items-center gap-1 text-xs text-red-500 hover:text-red-700 ' +
            'hover:bg-red-50 px-2 py-1 rounded transition">' +
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" ' +
            'd="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>' +
            '</svg>Delete</button>'
        ];
      });
    }

    function renderTable(checkins) {
      checkinTable.clear();
      checkinTable.rows.add(buildRows(checkins));
      checkinTable.draw();
    }

    function updateStats(checkins) {
      var customerCheckins = checkins.filter(function (c) { return c.customer_name !== 'Other'; });
      document.getElementById('stat-count').textContent = customerCheckins.length;
      var rev = checkins.reduce(function (s, c) { return s + (parseFloat(c.amount) || 0); }, 0);
      document.getElementById('stat-rev').textContent = Math.round(rev).toLocaleString('vi-VN') + ' ₫';
    }

    function refreshForRange() {
      var from = document.getElementById('view-from').value;
      var to   = document.getElementById('view-to').value;
      if (!from || !to) return;
      if (to < from) {
        document.getElementById('view-to').value = from;
        to = from;
      }
      activeFrom = from;
      activeTo   = to;
      document.getElementById('table-date-label').textContent =
        from === to ? formatDateLabel(from) : (from + ' → ' + to);
      loadCheckinsForRange(from, to);
    }

    function setQuick(period) {
      var now   = new Date();
      var today = now.toISOString().slice(0, 10);
      var from, to;
      if (period === 'today') {
        from = to = today;
      } else if (period === 'week') {
        var day = now.getDay(); // 0=Sun
        var mon = new Date(now); mon.setDate(now.getDate() - ((day + 6) % 7));
        var sun = new Date(mon); sun.setDate(mon.getDate() + 6);
        from = mon.toISOString().slice(0, 10);
        to   = sun.toISOString().slice(0, 10);
      } else if (period === 'month') {
        from = today.slice(0, 7) + '-01';
        var lastDay = new Date(now.getFullYear(), now.getMonth() + 1, 0);
        to = lastDay.toISOString().slice(0, 10);
      }
      document.getElementById('view-from').value = from;
      document.getElementById('view-to').value   = to;
      refreshForRange();
    }

    // ── Punch card: show/hide punch-from section on payment change ──
    document.getElementById('f-payment').addEventListener('change', function () {
      var isPunch   = this.value === 'Punch Card';
      var isPTPunch = this.value === 'PT Punch';
      document.getElementById('punch-from-row').classList.toggle('hidden', !isPunch);
      if (!isPunch) document.getElementById('f-punch-from').value = '';
      document.getElementById('pt-punch-from-row').classList.toggle('hidden', !isPTPunch);
      if (!isPTPunch) document.getElementById('f-pt-punch-from').value = '';
    });

    // ── Punch card: auto-select customer in punch dropdown when customer changes ──
    document.getElementById('f-customer').addEventListener('input', function () {
      clearTimeout(window._custDebounce);
      var name = this.value.trim();
      window._custDebounce = setTimeout(function () {
        var customer = allCustomers.find(function (c) { return c['Full Name'] === name; });
        if (!customer) return;
        var checkinDate = document.getElementById('f-checkin-date').value || new Date().toISOString().slice(0, 10);
        // Membership takes priority
        if (customer._membership_type && customer._membership_end_date && customer._membership_end_date >= checkinDate) {
          document.getElementById('f-payment').value = 'Valid Membership';
          document.getElementById('punch-from-row').classList.add('hidden');
          document.getElementById('f-punch-from').value = '';
        } else if (customer._is_punch_card_holder && customer._punches_remaining > 0) {
          // Auto-switch to Punch Card and pre-select this customer
          document.getElementById('f-payment').value = 'Punch Card';
          document.getElementById('punch-from-row').classList.remove('hidden');
          document.getElementById('f-punch-from').value = customer._id;
        }
      }, 300);
    });

    // ── Check-in type, add-ons & discount: auto-calculate amount ──
    function recalcAmount() {
      var typeSelect  = document.getElementById('f-checkin-type');
      var selectedOpt = typeSelect.options[typeSelect.selectedIndex];
      var basePrice   = selectedOpt ? (parseInt(selectedOpt.dataset.price || '0') || 0) : 0;
      var addonTotal  = 0;
      document.querySelectorAll('.addon-cb:checked').forEach(function (cb) {
        addonTotal += parseInt(cb.dataset.price || '0') || 0;
      });
      var discountRb  = document.querySelector('.discount-rb:checked');
      var discountVal = discountRb ? discountRb.value : '';
      var total;
      if (discountVal === 'day30') {
        total = Math.round(basePrice * 0.7) + addonTotal;
      } else if (discountVal === 'day40') {
        total = Math.round(basePrice * 0.6) + addonTotal;
      } else if (discountVal === 'lasthour50') {
        total = Math.round(basePrice * 0.5) + addonTotal;
      } else if (discountVal === 'birthday') {
        total = Math.max(0, (basePrice + addonTotal) - 20000);
      } else {
        total = basePrice + addonTotal;
      }
      document.getElementById('f-amount').value = total > 0 ? total : '';
    }
    document.getElementById('f-checkin-type').addEventListener('change', recalcAmount);
    document.querySelectorAll('.addon-cb').forEach(function (cb) {
      cb.addEventListener('change', recalcAmount);
    });
    document.querySelectorAll('.discount-rb').forEach(function (rb) {
      rb.addEventListener('change', recalcAmount);
    });

    function toggleAddons() {
      var body    = document.getElementById('addons-body');
      var chevron = document.getElementById('addons-chevron');
      var nowHidden = body.classList.toggle('hidden');
      chevron.classList.toggle('rotate-180', !nowHidden);
    }
    function toggleDiscount() {
      var body    = document.getElementById('discount-body');
      var chevron = document.getElementById('discount-chevron');
      var nowHidden = body.classList.toggle('hidden');
      chevron.classList.toggle('rotate-180', !nowHidden);
    }

    // ── Form submit ──
    document.getElementById('checkin-form').addEventListener('submit', function (e) {
      e.preventDefault();
      var errEl = document.getElementById('form-error');
      errEl.classList.add('hidden');

      var customerName  = document.getElementById('f-customer').value.trim();
      var payment        = document.getElementById('f-payment').value;
      var amount         = document.getElementById('f-amount').value;
      var notes          = document.getElementById('f-notes').value.trim();
      var checkinType    = document.getElementById('f-checkin-type').value;
      var addonsArr      = [];
      document.querySelectorAll('.addon-cb:checked').forEach(function (cb) { addonsArr.push(cb.dataset.name); });
      var DISCOUNT_LABELS = {
        'day30':      '30% discount – Day Pass (setting day, less disturbance)',
        'day40':      '40% discount – Day Pass (setting day, more disturbance)',
        'lasthour50': '50% discount – Day Pass (late entry)',
        'birthday':   'Birthday discount'
      };
      var discountRbSub  = document.querySelector('.discount-rb:checked');
      var discountValSub = discountRbSub ? discountRbSub.value : '';
      if (discountValSub && DISCOUNT_LABELS[discountValSub]) addonsArr.push('Discount: ' + DISCOUNT_LABELS[discountValSub]);
      var addonsStr      = addonsArr.join(', ');
      var punchFromSel   = document.getElementById('f-punch-from');
      var punchHolderId  = '';
      var punchHolderName = '';
      if (payment === 'Punch Card') {
        punchHolderId = punchFromSel.value;
        if (!punchHolderId) {
          errEl.textContent = 'Please select a punch card holder.';
          errEl.classList.remove('hidden'); return;
        }
        var selectedOpt = punchFromSel.options[punchFromSel.selectedIndex];
        punchHolderName = (selectedOpt && selectedOpt.dataset.holderName) || selectedOpt.textContent.split(' (')[0];
      }

      var ptPunchFromSel   = document.getElementById('f-pt-punch-from');
      var ptPunchHolderId  = '';
      var ptPunchHolderName = '';
      if (payment === 'PT Punch') {
        ptPunchHolderId = ptPunchFromSel.value;
        if (!ptPunchHolderId) {
          errEl.textContent = 'Please select a PT punch holder.';
          errEl.classList.remove('hidden'); return;
        }
        var selectedPTOpt = ptPunchFromSel.options[ptPunchFromSel.selectedIndex];
        ptPunchHolderName = (selectedPTOpt && selectedPTOpt.dataset.holderName) || selectedPTOpt.textContent.split(' (')[0];
      }

      if (!customerName) {
        errEl.textContent = 'Please enter a customer name.';
        errEl.classList.remove('hidden'); return;
      }
      if (!payment) {
        errEl.textContent = 'Please select a payment method.';
        errEl.classList.remove('hidden'); return;
      }

      var now     = new Date();
      var dateStr = document.getElementById('f-checkin-date').value || now.toISOString().slice(0, 10);
      var timeStr = document.getElementById('f-checkin-time').value || now.toTimeString().slice(0, 5);

      var btn = e.target.querySelector('[type="submit"]');
      btn.disabled = true;

      apiFetch('/api/checkins', {
        method: 'POST',
        body: JSON.stringify({
          customer_name:        customerName,
          date:                 dateStr,
          time:                 timeStr,
          payment_method:       payment,
          amount:               amount ? parseFloat(amount) : 0,
          notes:                notes,
          checkin_type:         checkinType,
          addons:               addonsStr,
          punch_card_holder_id:   punchHolderId   || undefined,
          punch_card_holder_name: punchHolderName || undefined,
          pt_punch_holder_id:     ptPunchHolderId   || undefined,
          pt_punch_holder_name:   ptPunchHolderName || undefined,
        })
      })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          btn.disabled = false;
          if (data.error) { errEl.textContent = data.error; errEl.classList.remove('hidden'); return; }
          // Switch viewing date to the submitted date so the new entry is visible
          activeFrom = dateStr;
          activeTo   = dateStr;
          document.getElementById('view-from').value = dateStr;
          document.getElementById('view-to').value   = dateStr;
          document.getElementById('table-date-label').textContent = formatDateLabel(dateStr);
          loadCheckinsForRange(dateStr, dateStr);
          // Refresh punch card dropdown counts if a punch was used
          if (punchHolderId || ptPunchHolderId) buildCustomerDatalist();
          document.getElementById('f-customer').value   = '';
          document.getElementById('f-payment').value    = '';
          document.getElementById('f-checkin-type').value = '';
          document.querySelectorAll('.addon-cb').forEach(function (cb) { cb.checked = false; });
          var noDiscRb = document.querySelector('.discount-rb[value=""]');
          if (noDiscRb) noDiscRb.checked = true;
          document.getElementById('f-amount').value     = '';
          document.getElementById('f-notes').value      = '';
          document.getElementById('f-punch-from').value = '';
          document.getElementById('punch-from-row').classList.add('hidden');
          document.getElementById('f-pt-punch-from').value = '';
          document.getElementById('pt-punch-from-row').classList.add('hidden');
          // Reset date+time to now for next entry
          var n = new Date();
          document.getElementById('f-checkin-date').value = n.toISOString().slice(0, 10);
          document.getElementById('f-checkin-time').value = n.toTimeString().slice(0, 5);
          updateTsPreview();
          showToast('✓ Check-in recorded for ' + customerName + '!');
          document.getElementById('f-customer').focus();
        })
        .catch(function (err) {
          btn.disabled = false;
          errEl.textContent = 'Save failed: ' + err.message;
          errEl.classList.remove('hidden');
        });
    });

    function deleteCheckin(id) {
      if (!confirm('Delete this check-in record?')) return;
      apiFetch('/api/checkins/' + id, { method: 'DELETE' })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.error) { showToast('Delete failed: ' + data.error, 'error'); return; }
          loadCheckinsForRange(activeFrom, activeTo);
          buildCustomerDatalist();
          showToast('Check-in deleted.', 'warning');
        })
        .catch(function (err) { showToast('Delete failed: ' + err.message, 'error'); });
    }

    function exportCheckins() {
      if (!allCheckins.length) { showToast('No check-ins to export for this period.', 'warning'); return; }
      var label = activeFrom === activeTo ? activeFrom : (activeFrom + '_to_' + activeTo);
      var headers = ['Date', 'Time', 'Customer Name', 'Check-in Type', 'Payment Method', 'Amount', 'Add-ons', 'Punch From', 'PT Punch From', 'Notes'];
      var csvContent = [headers].concat(allCheckins.map(function (c) {
        return [c.date, (c.time || '').slice(0, 5), c.customer_name, c.checkin_type || '',
                c.payment_method, Math.round(c.amount || 0), c.addons || '',
                c.punch_card_holder_name || '', c.pt_punch_holder_name || '', c.notes || ''];
      })).map(function (row) {
        return row.map(function (v) { return '"' + String(v).replace(/"/g, '""') + '"'; }).join(',');
      }).join('\n');

      var blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href   = url; a.download = 'checkins-' + label + '.csv'; a.click();
      URL.revokeObjectURL(url);
    }

    function formatDateLabel(dateStr) {
      return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-MY', {
        weekday: 'short', year: 'numeric', month: 'short', day: 'numeric'
      });
    }

    function payBadge(pm) {
      return { 'Cash': 'bg-green-100 text-green-700', 'Local Card': 'bg-blue-100 text-blue-700',
               'International Card': 'bg-cyan-100 text-cyan-700',
               'Local Bank Transfer': 'bg-indigo-100 text-indigo-700', 'Complimentary': 'bg-gray-100 text-gray-600',
               'Punch Card': 'bg-purple-100 text-purple-700', 'Valid Membership': 'bg-teal-100 text-teal-700' }[pm]
             || 'bg-orange-100 text-orange-700';
    }

    function escHtml(str) {
      return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function showToast(msg, type) {
      var t = document.createElement('div');
      t.textContent = msg;
      t.className = 'fixed bottom-6 right-6 z-50 px-4 py-2.5 rounded-lg text-sm font-medium shadow-lg ' +
        (type === 'warning' ? 'bg-yellow-500 text-white' : type === 'error' ? 'bg-red-500 text-white' : 'bg-green-500 text-white');
      document.body.appendChild(t);
      setTimeout(function () { t.remove(); }, 2500);
    }
  </script>
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Staff Schedule" activePage="schedule">

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- ── Add Entry Form ── -->
    <div class="xl:col-span-1">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="font-semibold text-gray-800 mb-5">Add Schedule Entry</h2>

        <form id="schedule-form" class="space-y-4" novalidate>

          <!-- Staff Name -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Staff Name <span class="text-red-400">*</span></label>
            <input
              id="f-staff"
              list="staff-list"
              type="text"
              placeholder="Select or type name…"
              autocomplete="off"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
            <!-- Staff name datalist — add your staff names here -->
            <datalist id="staff-list">
              <option value="Thanh Tu"></option>
              <option value="Duyen Ha"></option>
              <option value="Thu Huyen"></option>
              <option value="Kim An"></option>
              <option value="Khue Anh"></option>
              <option value="Huy Tran"></option>
            </datalist>
            <p class="text-xs text-gray-400 mt-1">Staff names can be configured in the source code.</p>
          </div>

          <!-- Date -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Date <span class="text-red-400">*</span></label>
            <input
              id="f-date"
              type="date"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
          </div>

          <!-- Start / End Time -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Start Time <span class="text-red-400">*</span></label>
              <input
                id="f-start"
                type="time"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">End Time <span class="text-red-400">*</span></label>
              <input
                id="f-end"
                type="time"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
              />
            </div>
          </div>

          <!-- Auto-calculated duration -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Duration</label>
            <div id="duration-display"
                 class="w-full border border-gray-200 bg-gray-50 rounded-lg px-3 py-2 text-sm text-gray-500">
              — (auto-calculated)
            </div>
          </div>

          <!-- Notes -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Notes</label>
            <input
              id="f-notes"
              type="text"
              placeholder="Optional…"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
            />
          </div>

          <!-- Form error -->
          <div id="form-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>

          <button
            type="submit"
            class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold
                   py-2.5 rounded-lg text-sm transition active:scale-[0.98]"
          >
            Add to Schedule
          </button>
        </form>
      </div>
    </div>

    <!-- ── Import CSV ── -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="font-semibold text-gray-800 mb-1">Import Schedule via CSV</h2>
      <p class="text-xs text-gray-400 mb-4">
        Upload a CSV with columns: <code class="bg-gray-100 px-1 rounded">staff_name, date, start_time, end_time, notes</code>
      </p>

      <div id="csv-drop-area"
           class="border-2 border-dashed border-gray-300 rounded-lg p-5 text-center cursor-pointer
                  hover:border-orange-400 hover:bg-orange-50/30 transition-colors mb-3"
           onclick="document.getElementById('csv-file-input').click()">
        <svg class="w-8 h-8 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        <p class="text-sm text-gray-500">Click to choose a CSV file</p>
        <p id="csv-file-name" class="text-xs text-gray-400 mt-1"></p>
      </div>

      <input id="csv-file-input" type="file" accept=".csv,text/csv" class="hidden" />

      <div id="csv-preview" class="hidden mb-3">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Preview</p>
        <div id="csv-preview-body" class="text-xs text-gray-700 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 max-h-32 overflow-y-auto space-y-0.5"></div>
      </div>

      <div id="csv-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded-lg px-3 py-2 mb-3"></div>

      <div class="flex items-center gap-2">
        <button id="btn-import-csv" disabled
                class="flex-1 bg-orange-500 hover:bg-orange-600 disabled:bg-gray-200 disabled:text-gray-400
                       text-white font-semibold py-2 rounded-lg text-sm transition">
          Import Rows
        </button>
        <a href="/assets/schedule-sample.csv" download
           class="inline-flex items-center gap-1 text-xs text-orange-500 hover:text-orange-600 font-medium whitespace-nowrap">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Sample CSV
        </a>
      </div>
    </div>

    <!-- ── Weekly Calendar ── -->
    <div class="xl:col-span-2">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">

        <!-- Header: title + week nav + export -->
        <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
          <h2 class="font-semibold text-gray-800">Weekly Schedule</h2>
          <div class="flex items-center gap-2 flex-wrap">
            <button id="btn-prev-week"
                    class="px-2.5 py-1.5 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600 transition">
              ‹ Prev
            </button>
            <span id="week-label" class="text-sm font-medium text-gray-700 min-w-[190px] text-center px-1"></span>
            <button id="btn-next-week"
                    class="px-2.5 py-1.5 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600 transition">
              Next ›
            </button>
            <button id="btn-today"
                    class="px-2.5 py-1.5 text-sm bg-orange-500 hover:bg-orange-600 text-white font-medium rounded-lg transition">
              Today
            </button>
            <button onclick="exportCSV()"
                    class="inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-gray-800
                           bg-gray-50 hover:bg-gray-100 border border-gray-200 px-3 py-1.5 rounded-lg transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
              Export CSV
            </button>
          </div>
        </div>

        <!-- Calendar grid: one row per staff, 7 day columns -->
        <div class="overflow-x-auto">
          <table id="cal-table" class="w-full border-collapse" style="min-width:560px">
            <thead id="cal-head"></thead>
            <tbody id="cal-body"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    var scheduleData = [];
    var currentWeekStart;

    var STAFF_NAMES = ['Thanh Tu', 'Duyen Ha', 'Thu Huyen', 'Kim An', 'Khue Anh', 'Huy Tran'];
    var STAFF_COLORS = [
      { bg: '#FED7AA', text: '#9A3412', border: '#FB923C' },
      { bg: '#BFDBFE', text: '#1E40AF', border: '#60A5FA' },
      { bg: '#BBF7D0', text: '#166534', border: '#4ADE80' },
      { bg: '#F5D0FE', text: '#7E22CE', border: '#E879F9' },
      { bg: '#FEF08A', text: '#854D0E', border: '#FACC15' },
      { bg: '#FECDD3', text: '#9F1239', border: '#FB7185' },
      { bg: '#CCFBF1', text: '#134E4A', border: '#34D399' },
      { bg: '#E0E7FF', text: '#3730A3', border: '#818CF8' }
    ];

    // ── API helper ──
    function apiFetch(url, options) {
      var token = sessionStorage.getItem('bbo_token') || '';
      var headers = { 'Authorization': 'Bearer ' + token };
      if (options && options.body) headers['Content-Type'] = 'application/json';
      return fetch(url, Object.assign({}, options, { headers: headers }));
    }

    $(document).ready(function () {
      document.getElementById('f-date').value = new Date().toISOString().slice(0, 10);
      currentWeekStart = getWeekStart(new Date());

      document.getElementById('btn-prev-week').addEventListener('click', function () {
        currentWeekStart = addDays(currentWeekStart, -7);
        renderCalendar();
      });
      document.getElementById('btn-next-week').addEventListener('click', function () {
        currentWeekStart = addDays(currentWeekStart, 7);
        renderCalendar();
      });
      document.getElementById('btn-today').addEventListener('click', function () {
        currentWeekStart = getWeekStart(new Date());
        renderCalendar();
      });

      loadSchedule();
      $('#f-start, #f-end').on('change', calcDuration);
    });

    // ── Week helpers ──
    function getWeekStart(date) {
      var d = new Date(date);
      d.setHours(0, 0, 0, 0);
      var day = d.getDay();
      d.setDate(d.getDate() + (day === 0 ? -6 : 1 - day)); // Monday
      return d;
    }

    function addDays(date, n) {
      var d = new Date(date);
      d.setDate(d.getDate() + n);
      return d;
    }

    function fmtDate(date) {
      var y = date.getFullYear();
      var m = String(date.getMonth() + 1).padStart(2, '0');
      var dd = String(date.getDate()).padStart(2, '0');
      return y + '-' + m + '-' + dd;
    }

    function fmtWeekLabel(start) {
      var end = addDays(start, 6);
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return months[start.getMonth()] + ' ' + start.getDate() +
             ' – ' + months[end.getMonth()] + ' ' + end.getDate() +
             ', ' + end.getFullYear();
    }

    function getStaffList() {
      var list = STAFF_NAMES.slice();
      scheduleData.forEach(function (s) {
        if (list.indexOf(s.staff_name) === -1) list.push(s.staff_name);
      });
      return list;
    }

    // ── Render calendar ──
    function renderCalendar() {
      var DAY_ABBR = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      var weekDates = [];
      for (var i = 0; i < 7; i++) weekDates.push(addDays(currentWeekStart, i));
      var todayIso = fmtDate(new Date());

      document.getElementById('week-label').textContent = fmtWeekLabel(currentWeekStart);

      // Head row
      var headHtml = '<tr class="border-b-2 border-gray-200">';
      headHtml += '<th class="w-24 pb-3 pr-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Staff</th>';
      weekDates.forEach(function (d) {
        var isToday = fmtDate(d) === todayIso;
        var abbr    = DAY_ABBR[d.getDay()];
        var num     = d.getDate();
        if (isToday) {
          headHtml += '<th class="pb-3 px-1 text-center">' +
            '<span class="block text-xs font-semibold text-orange-500 uppercase tracking-wide">' + abbr + '</span>' +
            '<span class="mt-0.5 w-7 h-7 rounded-full bg-orange-500 text-white text-sm font-bold inline-flex items-center justify-center mx-auto">' + num + '</span>' +
            '</th>';
        } else {
          headHtml += '<th class="pb-3 px-1 text-center">' +
            '<span class="block text-xs font-semibold text-gray-400 uppercase tracking-wide">' + abbr + '</span>' +
            '<span class="block text-sm font-medium text-gray-700">' + num + '</span>' +
            '</th>';
        }
      });
      headHtml += '</tr>';
      document.getElementById('cal-head').innerHTML = headHtml;

      // Body rows — one per staff
      var staffList = getStaffList();
      var bodyHtml  = '';
      staffList.forEach(function (staffName, rowIdx) {
        var color  = STAFF_COLORS[rowIdx % STAFF_COLORS.length];
        var isLast = rowIdx === staffList.length - 1;
        bodyHtml += '<tr class="' + (isLast ? '' : 'border-b border-gray-100') + ' hover:bg-gray-50/40">';
        bodyHtml += '<td class="py-2.5 pr-3 align-top w-24">' +
          '<span class="text-xs font-semibold text-gray-700 leading-tight">' + escHtml(staffName) + '</span>' +
          '</td>';
        weekDates.forEach(function (d) {
          var iso     = fmtDate(d);
          var isToday = iso === todayIso;
          var entries = scheduleData.filter(function (s) {
            return s.staff_name === staffName && s.date === iso;
          });
          bodyHtml += '<td class="py-2 px-1 align-top' + (isToday ? ' bg-orange-50/30' : '') + '" style="min-width:80px">';
          entries.forEach(function (entry) {
            var start = entry.start_time || '';
            var end   = entry.end_time   || '';
            var diff  = timeToMin(end) - timeToMin(start);
            if (diff <= 0) diff += 1440;
            var h = Math.floor(diff / 60), m = diff % 60;
            var dur = h + 'h' + (m ? ' ' + m + 'm' : '');
            var safeId = escHtml(String(entry.id));
            bodyHtml +=
              '<div onclick="deleteEntry(\'' + safeId + '\')" ' +
              'title="Click to delete&#10;' + escHtml(staffName) + ': ' + start + '–' + end +
                (entry.notes ? '&#10;Note: ' + escHtml(entry.notes) : '') + '" ' +
              'class="mb-1 px-2 py-1 rounded-md cursor-pointer text-xs leading-snug border hover:opacity-75 transition-opacity" ' +
              'style="background:' + color.bg + ';color:' + color.text + ';border-color:' + color.border + '">' +
              '<div class="font-semibold whitespace-nowrap">' + start + '–' + end + '</div>' +
              '<div class="opacity-70 truncate">' + dur + (entry.notes ? ' · ' + escHtml(entry.notes) : '') + '</div>' +
              '</div>';
          });
          bodyHtml += '</td>';
        });
        bodyHtml += '</tr>';
      });

      if (!bodyHtml) {
        bodyHtml = '<tr><td colspan="8" class="py-10 text-center text-gray-400 text-sm">No schedule data yet.</td></tr>';
      }
      document.getElementById('cal-body').innerHTML = bodyHtml;
    }

    function calcDuration() {
      var s = document.getElementById('f-start').value;
      var e = document.getElementById('f-end').value;
      var el = document.getElementById('duration-display');
      if (s && e) {
        var diff = timeToMin(e) - timeToMin(s);
        if (diff <= 0) diff += 1440;
        var h = Math.floor(diff / 60), m = diff % 60;
        el.textContent = h + 'h ' + (m ? m + 'm' : '');
        el.classList.remove('text-gray-500');
        el.classList.add('text-gray-800', 'font-medium');
      } else {
        el.textContent = '— (auto-calculated)';
        el.classList.add('text-gray-500');
        el.classList.remove('text-gray-800', 'font-medium');
      }
    }

    function timeToMin(t) {
      if (!t) return 0;
      var p = t.split(':');
      return parseInt(p[0]) * 60 + parseInt(p[1]);
    }

    function loadSchedule() {
      apiFetch('/api/schedule')
        .then(function (res) { return res.json(); })
        .then(function (data) {
          scheduleData = data.entries || [];
          renderCalendar();
        })
        .catch(function (err) { showToast('Failed to load schedule: ' + err.message, 'error'); });
    }

    // Form submit
    document.getElementById('schedule-form').addEventListener('submit', function (e) {
      e.preventDefault();
      var errEl = document.getElementById('form-error');
      errEl.classList.add('hidden');

      var staff = document.getElementById('f-staff').value.trim();
      var date  = document.getElementById('f-date').value;
      var start = document.getElementById('f-start').value;
      var end   = document.getElementById('f-end').value;
      var notes = document.getElementById('f-notes').value.trim();

      if (!staff || !date || !start || !end) {
        errEl.textContent = 'Please fill in all required fields.';
        errEl.classList.remove('hidden');
        return;
      }

      var btn = e.target.querySelector('[type="submit"]');
      btn.disabled = true; btn.textContent = 'Saving…';

      apiFetch('/api/schedule', {
        method: 'POST',
        body: JSON.stringify({ staff_name: staff, date: date, start_time: start, end_time: end, notes: notes })
      })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          btn.disabled = false; btn.textContent = 'Add to Schedule';
          if (data.error) { errEl.textContent = data.error; errEl.classList.remove('hidden'); return; }
          scheduleData.unshift(data.entry);
          // Jump to the week of the newly added entry
          currentWeekStart = getWeekStart(new Date(date + 'T00:00:00'));
          renderCalendar();
          document.getElementById('f-staff').value = '';
          document.getElementById('f-start').value = '';
          document.getElementById('f-end').value   = '';
          document.getElementById('f-notes').value  = '';
          document.getElementById('duration-display').textContent = '— (auto-calculated)';
          document.getElementById('duration-display').className =
            'w-full border border-gray-200 bg-gray-50 rounded-lg px-3 py-2 text-sm text-gray-500';
          showToast('Schedule entry added!');
        })
        .catch(function (err) {
          btn.disabled = false; btn.textContent = 'Add to Schedule';
          errEl.textContent = 'Save failed: ' + err.message;
          errEl.classList.remove('hidden');
        });
    });

    function deleteEntry(id) {
      if (!confirm('Delete this schedule entry?')) return;
      apiFetch('/api/schedule/' + id, { method: 'DELETE' })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.error) { showToast('Delete failed: ' + data.error, 'error'); return; }
          scheduleData = scheduleData.filter(function (s) { return String(s.id) !== String(id); });
          renderCalendar();
          showToast('Entry deleted.', 'warning');
        })
        .catch(function (err) { showToast('Delete failed: ' + err.message, 'error'); });
    }

    function exportCSV() {
      var rows = [['Staff Name', 'Date', 'Start', 'End', 'Notes']];
      scheduleData.forEach(function (s) {
        rows.push([s.staff_name, s.date, s.start_time, s.end_time, s.notes || '']);
      });
      var csv = rows.map(function (r) {
        return r.map(function (c) { return '"' + String(c).replace(/"/g, '""') + '"'; }).join(',');
      }).join('\n');
      var blob = new Blob([csv], { type: 'text/csv' });
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href = url; a.download = 'staff-schedule.csv'; a.click();
      URL.revokeObjectURL(url);
    }

    function escHtml(str) {
      return String(str || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // ── CSV Import ──
    var csvParsedRows = [];

    document.getElementById('csv-file-input').addEventListener('change', function (e) {
      var file = e.target.files[0];
      if (!file) return;
      document.getElementById('csv-file-name').textContent = file.name;
      var reader = new FileReader();
      reader.onload = function (ev) { handleCSVText(ev.target.result); };
      reader.readAsText(file);
    });

    function parseCSVLine(line) {
      var result = [], cur = '', inQ = false;
      for (var i = 0; i < line.length; i++) {
        var c = line[i];
        if (c === '"') {
          if (inQ && line[i + 1] === '"') { cur += '"'; i++; }
          else inQ = !inQ;
        } else if (c === ',' && !inQ) { result.push(cur.trim()); cur = ''; }
        else cur += c;
      }
      result.push(cur.trim());
      return result;
    }

    function handleCSVText(text) {
      var errEl = document.getElementById('csv-error');
      errEl.classList.add('hidden');
      csvParsedRows = [];

      var lines = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n').filter(function (l) { return l.trim(); });
      if (lines.length < 2) {
        errEl.textContent = 'CSV must have a header row and at least one data row.';
        errEl.classList.remove('hidden');
        return;
      }

      var headers = parseCSVLine(lines[0]).map(function (h) { return h.toLowerCase().replace(/\s+/g, '_'); });
      var idxStaff = headers.indexOf('staff_name');
      var idxDate  = headers.indexOf('date');
      var idxStart = headers.indexOf('start_time');
      var idxEnd   = headers.indexOf('end_time');
      var idxNotes = headers.indexOf('notes');

      if (idxStaff === -1 || idxDate === -1 || idxStart === -1 || idxEnd === -1) {
        errEl.textContent = 'Missing required columns: staff_name, date, start_time, end_time';
        errEl.classList.remove('hidden');
        return;
      }

      var errors = [];
      for (var i = 1; i < lines.length; i++) {
        var cols = parseCSVLine(lines[i]);
        var staff = cols[idxStaff] || '';
        var date  = cols[idxDate]  || '';
        var start = cols[idxStart] || '';
        var end   = cols[idxEnd]   || '';
        var notes = idxNotes !== -1 ? (cols[idxNotes] || '') : '';

        if (!staff || !date || !start || !end) { errors.push('Row ' + i + ': missing required value'); continue; }
        if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) { errors.push('Row ' + i + ': date must be YYYY-MM-DD'); continue; }
        if (!/^\d{2}:\d{2}$/.test(start) || !/^\d{2}:\d{2}$/.test(end)) { errors.push('Row ' + i + ': times must be HH:MM'); continue; }

        csvParsedRows.push({ staff_name: staff, date: date, start_time: start, end_time: end, notes: notes });
      }

      if (errors.length) {
        errEl.textContent = errors.slice(0, 3).join(' | ') + (errors.length > 3 ? ' …and ' + (errors.length - 3) + ' more' : '');
        errEl.classList.remove('hidden');
      }

      if (csvParsedRows.length) {
        var previewBody = document.getElementById('csv-preview-body');
        previewBody.innerHTML = csvParsedRows.map(function (r) {
          return '<div class="py-0.5 border-b border-gray-100 last:border-0">' +
            escHtml(r.staff_name) + ' · ' + escHtml(r.date) + ' · ' + escHtml(r.start_time) + '–' + escHtml(r.end_time) +
            (r.notes ? ' <span class="text-gray-400">(' + escHtml(r.notes) + ')</span>' : '') + '</div>';
        }).join('');
        document.getElementById('csv-preview').classList.remove('hidden');
        document.getElementById('btn-import-csv').disabled = false;
        document.getElementById('btn-import-csv').textContent = 'Import ' + csvParsedRows.length + ' Row' + (csvParsedRows.length > 1 ? 's' : '');
      } else {
        document.getElementById('csv-preview').classList.add('hidden');
        document.getElementById('btn-import-csv').disabled = true;
        document.getElementById('btn-import-csv').textContent = 'Import Rows';
      }
    }

    document.getElementById('btn-import-csv').addEventListener('click', function () {
      if (!csvParsedRows.length) return;
      var btn = document.getElementById('btn-import-csv');
      btn.disabled = true; btn.textContent = 'Importing…';

      var promises = csvParsedRows.map(function (row) {
        return apiFetch('/api/schedule', { method: 'POST', body: JSON.stringify(row) })
          .then(function (res) { return res.json(); });
      });

      Promise.all(promises).then(function (results) {
        var succeeded = results.filter(function (r) { return r.entry; }).map(function (r) { return r.entry; });
        var failed    = results.filter(function (r) { return r.error; }).length;

        succeeded.forEach(function (entry) { scheduleData.unshift(entry); });
        renderCalendar();

        csvParsedRows = [];
        document.getElementById('csv-file-input').value = '';
        document.getElementById('csv-file-name').textContent = '';
        document.getElementById('csv-preview').classList.add('hidden');
        document.getElementById('btn-import-csv').disabled = true;
        document.getElementById('btn-import-csv').textContent = 'Import Rows';

        if (failed) showToast('Imported ' + succeeded.length + ', ' + failed + ' failed.', 'warning');
        else showToast('Imported ' + succeeded.length + ' schedule row' + (succeeded.length > 1 ? 's' : '') + '!');
      }).catch(function (err) {
        btn.disabled = false;
        btn.textContent = 'Import Rows';
        showToast('Import failed: ' + err.message, 'error');
      });
    });

    function showToast(msg, type) {
      var t = document.createElement('div');
      t.textContent = msg;
      t.className = 'fixed bottom-6 right-6 z-50 px-4 py-2.5 rounded-lg text-sm font-medium shadow-lg ' +
        (type === 'warning' ? 'bg-yellow-500 text-white' : type === 'error' ? 'bg-red-500 text-white' : 'bg-green-500 text-white');
      document.body.appendChild(t);
      setTimeout(function () { t.remove(); }, 2500);
    }
  </script>
</MainLayout>

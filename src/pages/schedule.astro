---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Staff Schedule" activePage="schedule">

  <!-- ══ Page-level tabs ══ -->
  <div class="flex border-b border-gray-200 mb-6">
    <button id="page-tab-staff" type="button" onclick="switchPageTab('staff')"
      class="px-5 py-3 text-sm font-semibold text-orange-500 border-b-2 border-orange-500 -mb-px transition">
      Staff Schedule
    </button>
    <button id="page-tab-route" type="button" onclick="switchPageTab('route')"
      class="px-5 py-3 text-sm font-medium text-gray-400 border-b-2 border-transparent -mb-px hover:text-gray-600 transition">
      Route Setting Schedule
    </button>
  </div>

  <!-- ══ Tab 1: Staff Schedule ══ -->
  <div id="page-panel-staff">
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- ── Add / Bulk Entry ── -->
    <div class="xl:col-span-1">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">

        <!-- Tab bar -->
        <div class="flex border-b border-gray-200 mb-5 -mx-6 px-6">
          <button id="tab-single" type="button" onclick="switchTab('single')"
            class="flex-1 pb-2.5 text-sm font-semibold text-orange-500 border-b-2 border-orange-500 -mb-px transition">
            Single Entry
          </button>
          <button id="tab-bulk" type="button" onclick="switchTab('bulk')"
            class="flex-1 pb-2.5 text-sm font-medium text-gray-400 border-b-2 border-transparent -mb-px hover:text-gray-600 transition">
            Bulk Add
          </button>
        </div>

        <!-- ── Single Entry panel ── -->
        <div id="panel-single">
          <form id="schedule-form" class="space-y-4" novalidate>

            <!-- Staff Name -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Staff Name <span class="text-red-400">*</span></label>
              <input
                id="f-staff"
                list="staff-list"
                type="text"
                placeholder="Select or type name…"
                autocomplete="off"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
              />
              <!-- Staff name datalist — add your staff names here -->
              <datalist id="staff-list">
                <option value="Thanh Tu"></option>
                <option value="Duyen Ha"></option>
                <option value="Thu Huyen"></option>
                <option value="Kim An"></option>
                <option value="Khue Anh"></option>
                <option value="Huy Tran"></option>
              </datalist>
              <p class="text-xs text-gray-400 mt-1">Staff names can be configured in the source code.</p>
            </div>

            <!-- Date -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Date <span class="text-red-400">*</span></label>
              <input
                id="f-date"
                type="date"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
              />
            </div>

            <!-- Start / End Time -->
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Start Time <span class="text-red-400">*</span></label>
                <input
                  id="f-start"
                  type="time"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                         focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">End Time <span class="text-red-400">*</span></label>
                <input
                  id="f-end"
                  type="time"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                         focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
                />
              </div>
            </div>

            <!-- Auto-calculated duration -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Duration</label>
              <div id="duration-display"
                   class="w-full border border-gray-200 bg-gray-50 rounded-lg px-3 py-2 text-sm text-gray-500">
                — (auto-calculated)
              </div>
            </div>

            <!-- Notes -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Notes</label>
              <input
                id="f-notes"
                type="text"
                placeholder="Optional…"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent"
              />
            </div>

            <!-- Form error -->
            <div id="form-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>

            <button
              type="submit"
              class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold
                     py-2.5 rounded-lg text-sm transition active:scale-[0.98]"
            >
              Add to Schedule
            </button>
          </form>
        </div>

        <!-- ── Bulk Add panel ── -->
        <div id="panel-bulk" class="hidden">
          <form id="bulk-form" class="space-y-4" novalidate>

            <!-- Staff checkboxes -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label class="block text-sm font-medium text-gray-700">Staff Members <span class="text-red-400">*</span></label>
                <button type="button" id="btn-select-all-staff" onclick="toggleSelectAllStaff()"
                  class="text-xs text-orange-500 hover:text-orange-600 font-medium">
                  Select All
                </button>
              </div>
              <div id="staff-checkboxes"
                   class="border border-gray-200 rounded-lg p-3 space-y-2 max-h-44 overflow-y-auto">
                <!-- populated by JS -->
              </div>
            </div>

            <!-- Date range -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Date Range <span class="text-red-400">*</span></label>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <span class="block text-xs text-gray-500 mb-1">From</span>
                  <input id="b-date-from" type="date"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
                </div>
                <div>
                  <span class="block text-xs text-gray-500 mb-1">To</span>
                  <input id="b-date-to" type="date"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
                </div>
              </div>
            </div>

            <!-- Days of week -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Days of Week <span class="text-red-400">*</span></label>
              <div class="flex flex-wrap gap-x-3 gap-y-2">
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="bulk-dow accent-orange-500 w-3.5 h-3.5" value="1" checked />
                  <span class="text-xs font-medium text-gray-700">Mon</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="bulk-dow accent-orange-500 w-3.5 h-3.5" value="2" checked />
                  <span class="text-xs font-medium text-gray-700">Tue</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="bulk-dow accent-orange-500 w-3.5 h-3.5" value="3" checked />
                  <span class="text-xs font-medium text-gray-700">Wed</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="bulk-dow accent-orange-500 w-3.5 h-3.5" value="4" checked />
                  <span class="text-xs font-medium text-gray-700">Thu</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="bulk-dow accent-orange-500 w-3.5 h-3.5" value="5" checked />
                  <span class="text-xs font-medium text-gray-700">Fri</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="bulk-dow accent-orange-500 w-3.5 h-3.5" value="6" />
                  <span class="text-xs font-medium text-gray-700">Sat</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="bulk-dow accent-orange-500 w-3.5 h-3.5" value="0" />
                  <span class="text-xs font-medium text-gray-700">Sun</span>
                </label>
              </div>
            </div>

            <!-- Start / End Time -->
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Start Time <span class="text-red-400">*</span></label>
                <input id="b-start" type="time"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                         focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">End Time <span class="text-red-400">*</span></label>
                <input id="b-end" type="time"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                         focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
              </div>
            </div>

            <!-- Live entry count preview -->
            <div id="bulk-preview"
                 class="text-xs bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-gray-500">
              Select staff and dates to preview entry count.
            </div>

            <!-- Notes -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Notes</label>
              <input id="b-notes" type="text" placeholder="Optional…"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
            </div>

            <!-- Bulk error -->
            <div id="bulk-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>

            <button type="submit"
              class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold
                     py-2.5 rounded-lg text-sm transition active:scale-[0.98]">
              Add to Schedule
            </button>
          </form>
        </div>

      </div>
    </div>

    <!-- ── Import CSV ── -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h2 class="font-semibold text-gray-800 mb-1">Import Schedule via CSV</h2>
      <p class="text-xs text-gray-400 mb-4">
        Upload a CSV with columns: <code class="bg-gray-100 px-1 rounded">staff_name, date, start_time, end_time, notes</code>
      </p>

      <div id="csv-drop-area"
           class="border-2 border-dashed border-gray-300 rounded-lg p-5 text-center cursor-pointer
                  hover:border-orange-400 hover:bg-orange-50/30 transition-colors mb-3"
           onclick="document.getElementById('csv-file-input').click()">
        <svg class="w-8 h-8 mx-auto text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        <p class="text-sm text-gray-500">Click to choose a CSV file</p>
        <p id="csv-file-name" class="text-xs text-gray-400 mt-1"></p>
      </div>

      <input id="csv-file-input" type="file" accept=".csv,text/csv" class="hidden" />

      <div id="csv-preview" class="hidden mb-3">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Preview</p>
        <div id="csv-preview-body" class="text-xs text-gray-700 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 max-h-32 overflow-y-auto space-y-0.5"></div>
      </div>

      <div id="csv-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded-lg px-3 py-2 mb-3"></div>

      <div class="flex items-center gap-2">
        <button id="btn-import-csv" disabled
                class="flex-1 bg-orange-500 hover:bg-orange-600 disabled:bg-gray-200 disabled:text-gray-400
                       text-white font-semibold py-2 rounded-lg text-sm transition">
          Import Rows
        </button>
        <a href="/assets/schedule-sample.csv" download
           class="inline-flex items-center gap-1 text-xs text-orange-500 hover:text-orange-600 font-medium whitespace-nowrap">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Sample CSV
        </a>
      </div>
    </div>

    <!-- ── Weekly Calendar ── -->
    <div class="xl:col-span-2">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">

        <!-- Header: title + week nav + export -->
        <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
          <h2 class="font-semibold text-gray-800">Weekly Schedule</h2>
          <div class="flex items-center gap-2 flex-wrap">
            <button id="btn-prev-week"
                    class="px-2.5 py-1.5 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600 transition">
              ‹ Prev
            </button>
            <span id="week-label" class="text-sm font-medium text-gray-700 min-w-[190px] text-center px-1"></span>
            <button id="btn-next-week"
                    class="px-2.5 py-1.5 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600 transition">
              Next ›
            </button>
            <button id="btn-today"
                    class="px-2.5 py-1.5 text-sm bg-orange-500 hover:bg-orange-600 text-white font-medium rounded-lg transition">
              Today
            </button>
            <button onclick="duplicateToNextWeek()"
                    class="inline-flex items-center gap-1.5 text-sm text-indigo-600 hover:text-indigo-800
                           bg-indigo-50 hover:bg-indigo-100 border border-indigo-200 px-3 py-1.5 rounded-lg transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              Duplicate to Next Week
            </button>
            <button onclick="exportCSV()"
                    class="inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-gray-800
                           bg-gray-50 hover:bg-gray-100 border border-gray-200 px-3 py-1.5 rounded-lg transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
              Export CSV
            </button>
          </div>
        </div>

        <!-- Calendar grid: one row per staff, 7 day columns -->
        <div class="overflow-x-auto">
          <table id="cal-table" class="w-full border-collapse" style="min-width:560px">
            <thead id="cal-head"></thead>
            <tbody id="cal-body"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Edit Schedule Entry Modal ── -->
  <div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40"
       onclick="if(event.target===this)closeEditModal()">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm mx-4 p-6">
      <h3 class="font-semibold text-gray-800 text-base mb-4">Edit Schedule Entry</h3>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Staff Name <span class="text-red-400">*</span></label>
          <input id="e-staff" list="staff-list" type="text" placeholder="Select or type name…" autocomplete="off"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Date <span class="text-red-400">*</span></label>
          <input id="e-date" type="date"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Start Time <span class="text-red-400">*</span></label>
            <input id="e-start" type="time"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">End Time <span class="text-red-400">*</span></label>
            <input id="e-end" type="time"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                     focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Notes</label>
          <input id="e-notes" type="text" placeholder="Optional…"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                   focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" />
        </div>
        <div id="edit-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
      </div>
      <div class="flex gap-3 mt-5">
        <button onclick="closeEditModal()" type="button"
          class="flex-1 border border-gray-300 text-gray-700 font-medium py-2 rounded-lg text-sm hover:bg-gray-50 transition">
          Cancel
        </button>
        <button id="edit-save-btn" onclick="submitEdit()" type="button"
          class="flex-1 bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 rounded-lg text-sm transition active:scale-[0.98]">
          Save Changes
        </button>
      </div>
    </div>
  </div>

  </div><!-- end #page-panel-staff -->

  <!-- ══ Tab 2: Route Setting Schedule ══ -->
  <div id="page-panel-route" class="hidden">
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

      <!-- ── Route Setting Form (1 col) ── -->
      <div class="xl:col-span-1">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="font-semibold text-gray-800 mb-4">Log Setting Session</h2>
          <form id="rs-form" class="space-y-4" novalidate>

            <!-- Setting Date -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Setting Date <span class="text-red-400">*</span></label>
              <input id="rs-date" type="date"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
            </div>

            <!-- Reset Wall -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Reset Wall <span class="text-red-400">*</span></label>
              <div class="border border-gray-200 rounded-lg p-3 grid grid-cols-2 gap-2">
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-wall-cb accent-purple-600 w-3.5 h-3.5" value="W1" />
                  <span class="text-sm text-gray-700">W1 — Overhang 20</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-wall-cb accent-purple-600 w-3.5 h-3.5" value="W2" />
                  <span class="text-sm text-gray-700">W2 — Vertical</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-wall-cb accent-purple-600 w-3.5 h-3.5" value="W3" />
                  <span class="text-sm text-gray-700">W3 — Overhang 10</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-wall-cb accent-purple-600 w-3.5 h-3.5" value="W4" />
                  <span class="text-sm text-gray-700">W4 — Cave 60</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-wall-cb accent-purple-600 w-3.5 h-3.5" value="W5" />
                  <span class="text-sm text-gray-700">W5 — Overhang 40</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-wall-cb accent-purple-600 w-3.5 h-3.5" value="W6" />
                  <span class="text-sm text-gray-700">W6 — Slab</span>
                </label>
              </div>
            </div>

            <!-- Route Setters + route counts -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Route Setter <span class="text-red-400">*</span></label>
              <div class="border border-gray-200 rounded-lg p-3 space-y-2.5">
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-setter-cb accent-purple-600 w-3.5 h-3.5" value="Thanh Tu" onchange="toggleSetterInput(this)" />
                  <span class="text-sm text-gray-700 flex-1">Thanh Tu</span>
                  <input type="number" class="rs-routes-input hidden w-20 border border-gray-300 rounded-lg px-2 py-1 text-sm text-center
                         focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                    data-setter="Thanh Tu" min="1" max="99" placeholder="# routes" />
                </label>
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-setter-cb accent-purple-600 w-3.5 h-3.5" value="Shingo" onchange="toggleSetterInput(this)" />
                  <span class="text-sm text-gray-700 flex-1">Shingo</span>
                  <input type="number" class="rs-routes-input hidden w-20 border border-gray-300 rounded-lg px-2 py-1 text-sm text-center
                         focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                    data-setter="Shingo" min="1" max="99" placeholder="# routes" />
                </label>
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-setter-cb accent-purple-600 w-3.5 h-3.5" value="Tran Huy" onchange="toggleSetterInput(this)" />
                  <span class="text-sm text-gray-700 flex-1">Tran Huy</span>
                  <input type="number" class="rs-routes-input hidden w-20 border border-gray-300 rounded-lg px-2 py-1 text-sm text-center
                         focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                    data-setter="Tran Huy" min="1" max="99" placeholder="# routes" />
                </label>
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-setter-cb accent-purple-600 w-3.5 h-3.5" value="Sam" onchange="toggleSetterInput(this)" />
                  <span class="text-sm text-gray-700 flex-1">Sam</span>
                  <input type="number" class="rs-routes-input hidden w-20 border border-gray-300 rounded-lg px-2 py-1 text-sm text-center
                         focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                    data-setter="Sam" min="1" max="99" placeholder="# routes" />
                </label>
                <label class="flex items-center gap-2 cursor-pointer select-none">
                  <input type="checkbox" class="rs-setter-cb accent-purple-600 w-3.5 h-3.5" value="Huy Le" onchange="toggleSetterInput(this)" />
                  <span class="text-sm text-gray-700 flex-1">Huy Le</span>
                  <input type="number" class="rs-routes-input hidden w-20 border border-gray-300 rounded-lg px-2 py-1 text-sm text-center
                         focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                    data-setter="Huy Le" min="1" max="99" placeholder="# routes" />
                </label>
              </div>
            </div>

            <!-- Setting Styles Coverage -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Setting Styles Coverage</label>
              <div class="flex flex-wrap gap-x-4 gap-y-2">
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="rs-style-cb accent-purple-600 w-3.5 h-3.5" value="Dynamic" />
                  <span class="text-sm text-gray-700">Dynamic</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="rs-style-cb accent-purple-600 w-3.5 h-3.5" value="Static" />
                  <span class="text-sm text-gray-700">Static</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="rs-style-cb accent-purple-600 w-3.5 h-3.5" value="Coordination" />
                  <span class="text-sm text-gray-700">Coordination</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="rs-style-cb accent-purple-600 w-3.5 h-3.5" value="Comp style" />
                  <span class="text-sm text-gray-700">Comp style</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer select-none">
                  <input type="checkbox" class="rs-style-cb accent-purple-600 w-3.5 h-3.5" value="Other" />
                  <span class="text-sm text-gray-700">Other</span>
                </label>
              </div>
            </div>

            <!-- Notes -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Notes</label>
              <input id="rs-notes" type="text" placeholder="Optional…"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                       focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
            </div>

            <div id="rs-form-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>

            <div class="flex gap-2">
              <button type="submit" id="rs-submit-btn"
                class="flex-1 bg-purple-600 hover:bg-purple-700 text-white font-semibold
                       py-2.5 rounded-lg text-sm transition active:scale-[0.98]">
                Save Session
              </button>
              <button type="button" id="rs-cancel-btn" onclick="cancelRSEdit()"
                class="hidden px-4 border border-gray-300 text-gray-700 font-medium py-2.5
                       rounded-lg text-sm hover:bg-gray-50 transition">
                Cancel
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- ── Monthly Calendar (2 cols) ── -->
      <div class="xl:col-span-2">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">

          <!-- Header: title + month nav -->
          <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
            <div>
              <h2 class="font-semibold text-gray-800">Route Setting Calendar</h2>
              <p class="text-xs text-gray-400 mt-0.5">Mondays highlighted — routesetting typically every other Monday</p>
            </div>
            <div class="flex items-center gap-2">
              <button id="rs-prev-month" type="button" onclick="rsNavMonth(-1)"
                class="px-2.5 py-1.5 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600 transition">
                ‹ Prev
              </button>
              <span id="rs-month-label" class="text-sm font-medium text-gray-700 min-w-[160px] text-center px-1"></span>
              <button id="rs-next-month" type="button" onclick="rsNavMonth(1)"
                class="px-2.5 py-1.5 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600 transition">
                Next ›
              </button>
              <button type="button" onclick="rsGoToday()"
                class="px-2.5 py-1.5 text-sm bg-purple-600 hover:bg-purple-700 text-white font-medium rounded-lg transition">
                Today
              </button>
            </div>
          </div>

          <!-- Calendar body -->
          <div class="overflow-x-auto">
            <div id="rs-calendar-body"></div>
          </div>
        </div>
      </div>

    </div>
  </div><!-- end #page-panel-route -->

  <script is:inline>
    var scheduleData = [];
    var currentWeekStart;

    var STAFF_NAMES = ['Thanh Tu', 'Duyen Ha', 'Thu Huyen', 'Kim An', 'Khue Anh', 'Huy Tran'];
    var STAFF_COLORS = [
      { bg: '#FED7AA', text: '#9A3412', border: '#FB923C' },
      { bg: '#BFDBFE', text: '#1E40AF', border: '#60A5FA' },
      { bg: '#BBF7D0', text: '#166534', border: '#4ADE80' },
      { bg: '#F5D0FE', text: '#7E22CE', border: '#E879F9' },
      { bg: '#FEF08A', text: '#854D0E', border: '#FACC15' },
      { bg: '#FECDD3', text: '#9F1239', border: '#FB7185' },
      { bg: '#CCFBF1', text: '#134E4A', border: '#34D399' },
      { bg: '#E0E7FF', text: '#3730A3', border: '#818CF8' }
    ];

    // ── API helper ──
    function apiFetch(url, options) {
      var token = sessionStorage.getItem('bbo_token') || '';
      var headers = { 'Authorization': 'Bearer ' + token };
      if (options && options.body) headers['Content-Type'] = 'application/json';
      return fetch(url, Object.assign({}, options, { headers: headers }));
    }

    $(document).ready(function () {
      document.getElementById('f-date').value = new Date().toISOString().slice(0, 10);
      currentWeekStart = getWeekStart(new Date());

      document.getElementById('btn-prev-week').addEventListener('click', function () {
        currentWeekStart = addDays(currentWeekStart, -7);
        renderCalendar();
      });
      document.getElementById('btn-next-week').addEventListener('click', function () {
        currentWeekStart = addDays(currentWeekStart, 7);
        renderCalendar();
      });
      document.getElementById('btn-today').addEventListener('click', function () {
        currentWeekStart = getWeekStart(new Date());
        renderCalendar();
      });

      loadSchedule();
      $('#f-start, #f-end').on('change', calcDuration);

      // Bulk panel init
      initStaffCheckboxes();
      document.getElementById('b-date-from').addEventListener('change', updateBulkPreview);
      document.getElementById('b-date-to').addEventListener('change', updateBulkPreview);
      document.querySelectorAll('.bulk-dow').forEach(function (cb) {
        cb.addEventListener('change', updateBulkPreview);
      });
    });

    // ── Week helpers ──
    function getWeekStart(date) {
      var d = new Date(date);
      d.setHours(0, 0, 0, 0);
      var day = d.getDay();
      d.setDate(d.getDate() + (day === 0 ? -6 : 1 - day)); // Monday
      return d;
    }

    function addDays(date, n) {
      var d = new Date(date);
      d.setDate(d.getDate() + n);
      return d;
    }

    function fmtDate(date) {
      var y = date.getFullYear();
      var m = String(date.getMonth() + 1).padStart(2, '0');
      var dd = String(date.getDate()).padStart(2, '0');
      return y + '-' + m + '-' + dd;
    }

    function fmtWeekLabel(start) {
      var end = addDays(start, 6);
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return months[start.getMonth()] + ' ' + start.getDate() +
             ' – ' + months[end.getMonth()] + ' ' + end.getDate() +
             ', ' + end.getFullYear();
    }

    function getStaffList() {
      var list = STAFF_NAMES.slice();
      scheduleData.forEach(function (s) {
        if (list.indexOf(s.staff_name) === -1) list.push(s.staff_name);
      });
      return list;
    }

    // ── Render calendar ──
    function renderCalendar() {
      var DAY_ABBR = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      var weekDates = [];
      for (var i = 0; i < 7; i++) weekDates.push(addDays(currentWeekStart, i));
      var todayIso = fmtDate(new Date());

      document.getElementById('week-label').textContent = fmtWeekLabel(currentWeekStart);

      // Head row
      var headHtml = '<tr class="border-b-2 border-gray-200">';
      headHtml += '<th class="w-24 pb-3 pr-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Staff</th>';
      weekDates.forEach(function (d) {
        var isToday = fmtDate(d) === todayIso;
        var abbr    = DAY_ABBR[d.getDay()];
        var num     = d.getDate();
        if (isToday) {
          headHtml += '<th class="pb-3 px-1 text-center">' +
            '<span class="block text-xs font-semibold text-orange-500 uppercase tracking-wide">' + abbr + '</span>' +
            '<span class="mt-0.5 w-7 h-7 rounded-full bg-orange-500 text-white text-sm font-bold inline-flex items-center justify-center mx-auto">' + num + '</span>' +
            '</th>';
        } else {
          headHtml += '<th class="pb-3 px-1 text-center">' +
            '<span class="block text-xs font-semibold text-gray-400 uppercase tracking-wide">' + abbr + '</span>' +
            '<span class="block text-sm font-medium text-gray-700">' + num + '</span>' +
            '</th>';
        }
      });
      headHtml += '<th class="pb-3 pl-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide whitespace-nowrap">Total hrs</th>';
      headHtml += '</tr>';
      document.getElementById('cal-head').innerHTML = headHtml;

      // Body rows — one per staff
      var staffList = getStaffList();
      var bodyHtml  = '';
      staffList.forEach(function (staffName, rowIdx) {
        var color  = STAFF_COLORS[rowIdx % STAFF_COLORS.length];
        var isLast = rowIdx === staffList.length - 1;
        bodyHtml += '<tr class="' + (isLast ? '' : 'border-b border-gray-100') + ' hover:bg-gray-50/40">';
        bodyHtml += '<td class="py-2.5 pr-3 align-top w-24">' +
          '<span class="text-xs font-semibold text-gray-700 leading-tight">' + escHtml(staffName) + '</span>' +
          '</td>';
        var weekTotalMin = 0;
        weekDates.forEach(function (d) {
          var iso     = fmtDate(d);
          var isToday = iso === todayIso;
          var entries = scheduleData.filter(function (s) {
            return s.staff_name === staffName && s.date === iso;
          });
          bodyHtml += '<td class="py-2 px-1 align-top' + (isToday ? ' bg-orange-50/30' : '') + '" style="min-width:80px">';
          entries.forEach(function (entry) {
            var start = entry.start_time || '';
            var end   = entry.end_time   || '';
            var diff  = timeToMin(end) - timeToMin(start);
            if (diff <= 0) diff += 1440;
            weekTotalMin += diff;
            var h = Math.floor(diff / 60), m = diff % 60;
            var dur = h + 'h' + (m ? ' ' + m + 'm' : '');
            var safeId = escHtml(String(entry.id));
            bodyHtml +=
              '<div ' +
              'title="' + escHtml(staffName) + ': ' + start + '–' + end +
                (entry.notes ? '&#10;Note: ' + escHtml(entry.notes) : '') + '" ' +
              'class="mb-1 px-2 py-1 rounded-md text-xs leading-snug border group" ' +
              'style="background:' + color.bg + ';color:' + color.text + ';border-color:' + color.border + '">' +
              '<div class="flex items-start justify-between gap-0.5">' +
              '<div>' +
              '<div class="font-semibold whitespace-nowrap">' + start + '–' + end + '</div>' +
              '<div class="opacity-70 truncate">' + dur + (entry.notes ? ' · ' + escHtml(entry.notes) : '') + '</div>' +
              '</div>' +
              '<div class="flex gap-0.5 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">' +
              '<button onclick="openEditModal(\'' + safeId + '\')" title="Edit entry" type="button" ' +
              'class="p-0.5 rounded hover:bg-black/10 transition-colors">' +
              '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>' +
              '</button>' +
              '<button onclick="deleteEntry(\'' + safeId + '\')" title="Delete entry" type="button" ' +
              'class="p-0.5 rounded hover:bg-black/10 transition-colors">' +
              '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>' +
              '</button>' +
              '</div>' +
              '</div>' +
              '</div>';
          });
          bodyHtml += '</td>';
        });
        var th = Math.floor(weekTotalMin / 60), tm = weekTotalMin % 60;
        var totalLabel = weekTotalMin > 0
          ? th + 'h' + (tm ? ' ' + tm + 'm' : '')
          : '<span class="text-gray-300">—</span>';
        bodyHtml += '<td class="py-2.5 pl-3 align-middle text-right">' +
          '<span class="text-xs font-semibold text-gray-700 whitespace-nowrap">' + totalLabel + '</span>' +
          '</td>';
        bodyHtml += '</tr>';
      });

      if (!bodyHtml) {
        bodyHtml = '<tr><td colspan="9" class="py-10 text-center text-gray-400 text-sm">No schedule data yet.</td></tr>';
      }
      document.getElementById('cal-body').innerHTML = bodyHtml;
    }

    function calcDuration() {
      var s = document.getElementById('f-start').value;
      var e = document.getElementById('f-end').value;
      var el = document.getElementById('duration-display');
      if (s && e) {
        var diff = timeToMin(e) - timeToMin(s);
        if (diff <= 0) diff += 1440;
        var h = Math.floor(diff / 60), m = diff % 60;
        el.textContent = h + 'h ' + (m ? m + 'm' : '');
        el.classList.remove('text-gray-500');
        el.classList.add('text-gray-800', 'font-medium');
      } else {
        el.textContent = '— (auto-calculated)';
        el.classList.add('text-gray-500');
        el.classList.remove('text-gray-800', 'font-medium');
      }
    }

    function timeToMin(t) {
      if (!t) return 0;
      var p = t.split(':');
      return parseInt(p[0]) * 60 + parseInt(p[1]);
    }

    function loadSchedule() {
      apiFetch('/api/schedule')
        .then(function (res) { return res.json(); })
        .then(function (data) {
          scheduleData = data.entries || [];
          renderCalendar();
        })
        .catch(function (err) { showToast('Failed to load schedule: ' + err.message, 'error'); });
    }

    // Form submit
    document.getElementById('schedule-form').addEventListener('submit', function (e) {
      e.preventDefault();
      var errEl = document.getElementById('form-error');
      errEl.classList.add('hidden');

      var staff = document.getElementById('f-staff').value.trim();
      var date  = document.getElementById('f-date').value;
      var start = document.getElementById('f-start').value;
      var end   = document.getElementById('f-end').value;
      var notes = document.getElementById('f-notes').value.trim();

      if (!staff || !date || !start || !end) {
        errEl.textContent = 'Please fill in all required fields.';
        errEl.classList.remove('hidden');
        return;
      }

      var btn = e.target.querySelector('[type="submit"]');
      btn.disabled = true; btn.textContent = 'Saving…';

      apiFetch('/api/schedule', {
        method: 'POST',
        body: JSON.stringify({ staff_name: staff, date: date, start_time: start, end_time: end, notes: notes })
      })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          btn.disabled = false; btn.textContent = 'Add to Schedule';
          if (data.error) { errEl.textContent = data.error; errEl.classList.remove('hidden'); return; }
          scheduleData.unshift(data.entry);
          // Jump to the week of the newly added entry
          currentWeekStart = getWeekStart(new Date(date + 'T00:00:00'));
          renderCalendar();
          document.getElementById('f-staff').value = '';
          document.getElementById('f-start').value = '';
          document.getElementById('f-end').value   = '';
          document.getElementById('f-notes').value  = '';
          document.getElementById('duration-display').textContent = '— (auto-calculated)';
          document.getElementById('duration-display').className =
            'w-full border border-gray-200 bg-gray-50 rounded-lg px-3 py-2 text-sm text-gray-500';
          showToast('Schedule entry added!');
        })
        .catch(function (err) {
          btn.disabled = false; btn.textContent = 'Add to Schedule';
          errEl.textContent = 'Save failed: ' + err.message;
          errEl.classList.remove('hidden');
        });
    });

    function deleteEntry(id) {
      if (!confirm('Delete this schedule entry?')) return;
      apiFetch('/api/schedule/' + id, { method: 'DELETE' })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.error) { showToast('Delete failed: ' + data.error, 'error'); return; }
          scheduleData = scheduleData.filter(function (s) { return String(s.id) !== String(id); });
          renderCalendar();
          showToast('Entry deleted.', 'warning');
        })
        .catch(function (err) { showToast('Delete failed: ' + err.message, 'error'); });
    }

    // ── Edit entry ──
    var editingId = null;

    function openEditModal(id) {
      var entry = scheduleData.filter(function (s) { return String(s.id) === String(id); })[0];
      if (!entry) return;
      editingId = id;
      document.getElementById('e-staff').value = entry.staff_name || '';
      document.getElementById('e-date').value  = entry.date || '';
      document.getElementById('e-start').value = entry.start_time || '';
      document.getElementById('e-end').value   = entry.end_time || '';
      document.getElementById('e-notes').value = entry.notes || '';
      document.getElementById('edit-error').classList.add('hidden');
      document.getElementById('edit-save-btn').disabled = false;
      document.getElementById('edit-save-btn').textContent = 'Save Changes';
      document.getElementById('edit-modal').classList.remove('hidden');
    }

    function closeEditModal() {
      document.getElementById('edit-modal').classList.add('hidden');
      editingId = null;
    }

    function submitEdit() {
      var errEl = document.getElementById('edit-error');
      errEl.classList.add('hidden');
      var staff = document.getElementById('e-staff').value.trim();
      var date  = document.getElementById('e-date').value;
      var start = document.getElementById('e-start').value;
      var end   = document.getElementById('e-end').value;
      var notes = document.getElementById('e-notes').value.trim();

      if (!staff || !date || !start || !end) {
        errEl.textContent = 'Please fill in all required fields.';
        errEl.classList.remove('hidden');
        return;
      }

      var saveBtn = document.getElementById('edit-save-btn');
      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving…';

      apiFetch('/api/schedule/' + editingId, {
        method: 'PATCH',
        body: JSON.stringify({ staff_name: staff, date: date, start_time: start, end_time: end, notes: notes })
      })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save Changes';
          if (data.error) { errEl.textContent = data.error; errEl.classList.remove('hidden'); return; }
          for (var i = 0; i < scheduleData.length; i++) {
            if (String(scheduleData[i].id) === String(editingId)) { scheduleData[i] = data.entry; break; }
          }
          closeEditModal();
          renderCalendar();
          showToast('Entry updated!');
        })
        .catch(function (err) {
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save Changes';
          errEl.textContent = 'Save failed: ' + err.message;
          errEl.classList.remove('hidden');
        });
    }

    function exportCSV() {
      var rows = [['Staff Name', 'Date', 'Start', 'End', 'Notes']];
      scheduleData.forEach(function (s) {
        rows.push([s.staff_name, s.date, s.start_time, s.end_time, s.notes || '']);
      });
      var csv = rows.map(function (r) {
        return r.map(function (c) { return '"' + String(c).replace(/"/g, '""') + '"'; }).join(',');
      }).join('\n');
      var blob = new Blob([csv], { type: 'text/csv' });
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href = url; a.download = 'staff-schedule.csv'; a.click();
      URL.revokeObjectURL(url);
    }

    function escHtml(str) {
      return String(str || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // ── CSV Import ──
    var csvParsedRows = [];

    document.getElementById('csv-file-input').addEventListener('change', function (e) {
      var file = e.target.files[0];
      if (!file) return;
      document.getElementById('csv-file-name').textContent = file.name;
      var reader = new FileReader();
      reader.onload = function (ev) { handleCSVText(ev.target.result); };
      reader.readAsText(file);
    });

    function parseCSVLine(line) {
      var result = [], cur = '', inQ = false;
      for (var i = 0; i < line.length; i++) {
        var c = line[i];
        if (c === '"') {
          if (inQ && line[i + 1] === '"') { cur += '"'; i++; }
          else inQ = !inQ;
        } else if (c === ',' && !inQ) { result.push(cur.trim()); cur = ''; }
        else cur += c;
      }
      result.push(cur.trim());
      return result;
    }

    function handleCSVText(text) {
      var errEl = document.getElementById('csv-error');
      errEl.classList.add('hidden');
      csvParsedRows = [];

      var lines = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n').filter(function (l) { return l.trim(); });
      if (lines.length < 2) {
        errEl.textContent = 'CSV must have a header row and at least one data row.';
        errEl.classList.remove('hidden');
        return;
      }

      var headers = parseCSVLine(lines[0]).map(function (h) { return h.toLowerCase().replace(/\s+/g, '_'); });
      var idxStaff = headers.indexOf('staff_name');
      var idxDate  = headers.indexOf('date');
      var idxStart = headers.indexOf('start_time');
      var idxEnd   = headers.indexOf('end_time');
      var idxNotes = headers.indexOf('notes');

      if (idxStaff === -1 || idxDate === -1 || idxStart === -1 || idxEnd === -1) {
        errEl.textContent = 'Missing required columns: staff_name, date, start_time, end_time';
        errEl.classList.remove('hidden');
        return;
      }

      var errors = [];
      for (var i = 1; i < lines.length; i++) {
        var cols = parseCSVLine(lines[i]);
        var staff = cols[idxStaff] || '';
        var date  = cols[idxDate]  || '';
        var start = cols[idxStart] || '';
        var end   = cols[idxEnd]   || '';
        var notes = idxNotes !== -1 ? (cols[idxNotes] || '') : '';

        if (!staff || !date || !start || !end) { errors.push('Row ' + i + ': missing required value'); continue; }
        if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) { errors.push('Row ' + i + ': date must be YYYY-MM-DD'); continue; }
        if (!/^\d{2}:\d{2}$/.test(start) || !/^\d{2}:\d{2}$/.test(end)) { errors.push('Row ' + i + ': times must be HH:MM'); continue; }

        csvParsedRows.push({ staff_name: staff, date: date, start_time: start, end_time: end, notes: notes });
      }

      if (errors.length) {
        errEl.textContent = errors.slice(0, 3).join(' | ') + (errors.length > 3 ? ' …and ' + (errors.length - 3) + ' more' : '');
        errEl.classList.remove('hidden');
      }

      if (csvParsedRows.length) {
        var previewBody = document.getElementById('csv-preview-body');
        previewBody.innerHTML = csvParsedRows.map(function (r) {
          return '<div class="py-0.5 border-b border-gray-100 last:border-0">' +
            escHtml(r.staff_name) + ' · ' + escHtml(r.date) + ' · ' + escHtml(r.start_time) + '–' + escHtml(r.end_time) +
            (r.notes ? ' <span class="text-gray-400">(' + escHtml(r.notes) + ')</span>' : '') + '</div>';
        }).join('');
        document.getElementById('csv-preview').classList.remove('hidden');
        document.getElementById('btn-import-csv').disabled = false;
        document.getElementById('btn-import-csv').textContent = 'Import ' + csvParsedRows.length + ' Row' + (csvParsedRows.length > 1 ? 's' : '');
      } else {
        document.getElementById('csv-preview').classList.add('hidden');
        document.getElementById('btn-import-csv').disabled = true;
        document.getElementById('btn-import-csv').textContent = 'Import Rows';
      }
    }

    document.getElementById('btn-import-csv').addEventListener('click', function () {
      if (!csvParsedRows.length) return;
      var btn = document.getElementById('btn-import-csv');
      btn.disabled = true; btn.textContent = 'Importing…';

      var promises = csvParsedRows.map(function (row) {
        return apiFetch('/api/schedule', { method: 'POST', body: JSON.stringify(row) })
          .then(function (res) { return res.json(); });
      });

      Promise.all(promises).then(function (results) {
        var succeeded = results.filter(function (r) { return r.entry; }).map(function (r) { return r.entry; });
        var failed    = results.filter(function (r) { return r.error; }).length;

        succeeded.forEach(function (entry) { scheduleData.unshift(entry); });
        renderCalendar();

        csvParsedRows = [];
        document.getElementById('csv-file-input').value = '';
        document.getElementById('csv-file-name').textContent = '';
        document.getElementById('csv-preview').classList.add('hidden');
        document.getElementById('btn-import-csv').disabled = true;
        document.getElementById('btn-import-csv').textContent = 'Import Rows';

        if (failed) showToast('Imported ' + succeeded.length + ', ' + failed + ' failed.', 'warning');
        else showToast('Imported ' + succeeded.length + ' schedule row' + (succeeded.length > 1 ? 's' : '') + '!');
      }).catch(function (err) {
        btn.disabled = false;
        btn.textContent = 'Import Rows';
        showToast('Import failed: ' + err.message, 'error');
      });
    });

    // ── Tab switching ──
    function switchTab(tab) {
      var isSingle = tab === 'single';
      document.getElementById('panel-single').classList.toggle('hidden', !isSingle);
      document.getElementById('panel-bulk').classList.toggle('hidden', isSingle);
      var tSingle = document.getElementById('tab-single');
      var tBulk   = document.getElementById('tab-bulk');
      var activeClass   = 'flex-1 pb-2.5 text-sm font-semibold text-orange-500 border-b-2 border-orange-500 -mb-px transition';
      var inactiveClass = 'flex-1 pb-2.5 text-sm font-medium text-gray-400 border-b-2 border-transparent -mb-px hover:text-gray-600 transition';
      tSingle.className = isSingle ? activeClass : inactiveClass;
      tBulk.className   = isSingle ? inactiveClass : activeClass;
    }

    // ── Staff checkboxes ──
    function initStaffCheckboxes() {
      var container = document.getElementById('staff-checkboxes');
      container.innerHTML = STAFF_NAMES.map(function (name) {
        return '<label class="flex items-center gap-2 cursor-pointer select-none">' +
          '<input type="checkbox" class="bulk-staff accent-orange-500 w-3.5 h-3.5" value="' + escHtml(name) + '" />' +
          '<span class="text-sm text-gray-700">' + escHtml(name) + '</span>' +
          '</label>';
      }).join('');
      container.querySelectorAll('.bulk-staff').forEach(function (cb) {
        cb.addEventListener('change', updateBulkPreview);
      });
    }

    var _allStaffSelected = false;

    function toggleSelectAllStaff() {
      _allStaffSelected = !_allStaffSelected;
      document.querySelectorAll('.bulk-staff').forEach(function (cb) { cb.checked = _allStaffSelected; });
      document.getElementById('btn-select-all-staff').textContent = _allStaffSelected ? 'Deselect All' : 'Select All';
      updateBulkPreview();
    }

    function getSelectedStaff() {
      return Array.from(document.querySelectorAll('.bulk-staff:checked')).map(function (cb) { return cb.value; });
    }

    function getSelectedDays() {
      return Array.from(document.querySelectorAll('.bulk-dow:checked')).map(function (cb) { return parseInt(cb.value, 10); });
    }

    function getDatesInRange(fromISO, toISO, days) {
      var dates = [];
      var cur = new Date(fromISO + 'T00:00:00');
      var end = new Date(toISO  + 'T00:00:00');
      if (cur > end || !days.length) return dates;
      while (cur <= end) {
        if (days.indexOf(cur.getDay()) !== -1) dates.push(fmtDate(cur));
        cur.setDate(cur.getDate() + 1);
      }
      return dates;
    }

    function updateBulkPreview() {
      var el      = document.getElementById('bulk-preview');
      var staff   = getSelectedStaff();
      var fromISO = document.getElementById('b-date-from').value;
      var toISO   = document.getElementById('b-date-to').value;
      var days    = getSelectedDays();

      if (!staff.length || !fromISO || !toISO || !days.length) {
        el.textContent = 'Select staff, a date range and at least one day to preview entry count.';
        el.className = 'text-xs bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-gray-500';
        return;
      }
      if (fromISO > toISO) {
        el.textContent = '"To" date must be on or after "From" date.';
        el.className = 'text-xs bg-red-50 border border-red-200 rounded-lg px-3 py-2 text-red-500';
        return;
      }
      var dates = getDatesInRange(fromISO, toISO, days);
      var total = staff.length * dates.length;
      if (!total) {
        el.textContent = 'No matching dates in the selected range for the chosen days.';
        el.className = 'text-xs bg-yellow-50 border border-yellow-200 rounded-lg px-3 py-2 text-yellow-700';
        return;
      }
      el.textContent = staff.length + ' staff × ' + dates.length + ' day' + (dates.length !== 1 ? 's' : '') +
                       ' = ' + total + ' entr' + (total !== 1 ? 'ies' : 'y') + ' will be created.';
      el.className = 'text-xs bg-orange-50 border border-orange-200 rounded-lg px-3 py-2 text-orange-700 font-medium';
    }

    // ── Bulk form submit ──
    document.getElementById('bulk-form').addEventListener('submit', function (e) {
      e.preventDefault();
      var errEl = document.getElementById('bulk-error');
      errEl.classList.add('hidden');

      var staff   = getSelectedStaff();
      var fromISO = document.getElementById('b-date-from').value;
      var toISO   = document.getElementById('b-date-to').value;
      var days    = getSelectedDays();
      var start   = document.getElementById('b-start').value;
      var end     = document.getElementById('b-end').value;
      var notes   = document.getElementById('b-notes').value.trim();

      if (!staff.length)  { errEl.textContent = 'Select at least one staff member.'; errEl.classList.remove('hidden'); return; }
      if (!fromISO || !toISO) { errEl.textContent = 'Please choose a date range.'; errEl.classList.remove('hidden'); return; }
      if (fromISO > toISO) { errEl.textContent = '"To" date must be on or after "From" date.'; errEl.classList.remove('hidden'); return; }
      if (!days.length)   { errEl.textContent = 'Select at least one day of the week.'; errEl.classList.remove('hidden'); return; }
      if (!start || !end) { errEl.textContent = 'Please fill in start and end times.'; errEl.classList.remove('hidden'); return; }

      var dates = getDatesInRange(fromISO, toISO, days);
      if (!dates.length)  { errEl.textContent = 'No matching dates in the selected range for the chosen days.'; errEl.classList.remove('hidden'); return; }

      var entries = [];
      staff.forEach(function (s) {
        dates.forEach(function (d) {
          entries.push({ staff_name: s, date: d, start_time: start, end_time: end, notes: notes });
        });
      });

      if (entries.length > 100 && !confirm('This will create ' + entries.length + ' entries. Continue?')) return;

      var btn = e.target.querySelector('[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Adding ' + entries.length + ' entr' + (entries.length !== 1 ? 'ies' : 'y') + '…';

      Promise.all(entries.map(function (row) {
        return apiFetch('/api/schedule', { method: 'POST', body: JSON.stringify(row) })
          .then(function (res) { return res.json(); });
      })).then(function (results) {
        btn.disabled = false; btn.textContent = 'Add to Schedule';
        var succeeded = results.filter(function (r) { return r.entry; }).map(function (r) { return r.entry; });
        var failed    = results.filter(function (r) { return r.error; }).length;
        succeeded.forEach(function (entry) { scheduleData.unshift(entry); });
        currentWeekStart = getWeekStart(new Date(fromISO + 'T00:00:00'));
        renderCalendar();
        if (failed) showToast('Added ' + succeeded.length + ', ' + failed + ' failed.', 'warning');
        else        showToast('Added ' + succeeded.length + ' schedule entr' + (succeeded.length !== 1 ? 'ies' : 'y') + '!');
      }).catch(function (err) {
        btn.disabled = false; btn.textContent = 'Add to Schedule';
        errEl.textContent = 'Error: ' + err.message;
        errEl.classList.remove('hidden');
      });
    });

    function duplicateToNextWeek() {
      // Collect all entries in the currently visible week
      var weekStart = fmtDate(currentWeekStart);
      var weekEnd   = fmtDate(addDays(currentWeekStart, 6));
      var thisWeekEntries = scheduleData.filter(function (s) {
        return s.date >= weekStart && s.date <= weekEnd;
      });
      if (!thisWeekEntries.length) {
        showToast('No entries in the current week to duplicate.', 'warning');
        return;
      }
      if (!confirm('Duplicate ' + thisWeekEntries.length + ' entr' + (thisWeekEntries.length !== 1 ? 'ies' : 'y') + ' to next week?')) return;

      var entries = thisWeekEntries.map(function (s) {
        var nextDate = fmtDate(addDays(new Date(s.date + 'T00:00:00'), 7));
        return { staff_name: s.staff_name, date: nextDate, start_time: s.start_time, end_time: s.end_time, notes: s.notes || '' };
      });

      Promise.all(entries.map(function (row) {
        return apiFetch('/api/schedule', { method: 'POST', body: JSON.stringify(row) })
          .then(function (res) { return res.json(); });
      })).then(function (results) {
        var succeeded = results.filter(function (r) { return r.entry; }).map(function (r) { return r.entry; });
        var failed    = results.filter(function (r) { return r.error; }).length;
        succeeded.forEach(function (entry) { scheduleData.unshift(entry); });
        // Navigate to next week so user can see the duplicated entries
        currentWeekStart = addDays(currentWeekStart, 7);
        renderCalendar();
        if (failed) showToast('Duplicated ' + succeeded.length + ', ' + failed + ' failed.', 'warning');
        else        showToast('Duplicated ' + succeeded.length + ' entr' + (succeeded.length !== 1 ? 'ies' : 'y') + ' to next week!');
      }).catch(function (err) {
        showToast('Duplicate failed: ' + err.message, 'error');
      });
    }

    function showToast(msg, type) {      var t = document.createElement('div');
      t.textContent = msg;
      t.className = 'fixed bottom-6 right-6 z-50 px-4 py-2.5 rounded-lg text-sm font-medium shadow-lg ' +
        (type === 'warning' ? 'bg-yellow-500 text-white' : type === 'error' ? 'bg-red-500 text-white' : 'bg-green-500 text-white');
      document.body.appendChild(t);
      setTimeout(function () { t.remove(); }, 2500);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // ── Page-level tab switching ──────────────────────────────────────────────
    // ══════════════════════════════════════════════════════════════════════════
    function switchPageTab(tab) {
      var isStaff = tab === 'staff';
      document.getElementById('page-panel-staff').classList.toggle('hidden', !isStaff);
      document.getElementById('page-panel-route').classList.toggle('hidden', isStaff);
      var activeClass   = 'px-5 py-3 text-sm font-semibold text-orange-500 border-b-2 border-orange-500 -mb-px transition';
      var inactiveClass = 'px-5 py-3 text-sm font-medium text-gray-400 border-b-2 border-transparent -mb-px hover:text-gray-600 transition';
      document.getElementById('page-tab-staff').className = isStaff ? activeClass : inactiveClass;
      document.getElementById('page-tab-route').className  = isStaff ? inactiveClass : activeClass;
      if (!isStaff && !rsDataLoaded) loadRSData();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // ── Route Setting Schedule ────────────────────────────────────────────────
    // ══════════════════════════════════════════════════════════════════════════
    var rsData       = [];
    var rsDataLoaded = false;
    var rsCurrentMonth;  // Date set to 1st of the currently displayed month
    var rsEditingId  = null;

    function tryParseJSON(str, fallback) {
      try { var v = JSON.parse(str); return Array.isArray(v) ? v : fallback; }
      catch (_) { return fallback; }
    }

    function parseRSEntry(e) {
      return {
        id:      e.id,
        date:    e.date,
        walls:   tryParseJSON(e.walls,   []),
        setters: tryParseJSON(e.setters, []),
        styles:  tryParseJSON(e.styles,  []),
        notes:   e.notes || ''
      };
    }

    function loadRSData() {
      rsDataLoaded = true;
      apiFetch('/api/routesetting')
        .then(function (res) { return res.json(); })
        .then(function (data) {
          rsData = (data.entries || []).map(parseRSEntry);
          renderRSCalendar();
        })
        .catch(function (err) { showToast('Failed to load routesetting data: ' + err.message, 'error'); });
    }

    // ── Monthly calendar renderer ─────────────────────────────────────────────
    function getMonthStart(date) {
      return new Date(date.getFullYear(), date.getMonth(), 1);
    }

    function renderRSCalendar() {
      if (!rsCurrentMonth) rsCurrentMonth = getMonthStart(new Date());

      var MONTH_NAMES = ['January','February','March','April','May','June',
                         'July','August','September','October','November','December'];
      document.getElementById('rs-month-label').textContent =
        MONTH_NAMES[rsCurrentMonth.getMonth()] + ' ' + rsCurrentMonth.getFullYear();

      // Find the Monday on or before the 1st of the month
      var firstDay = new Date(rsCurrentMonth);
      var dow = firstDay.getDay(); // 0=Sun .. 6=Sat
      var offset = dow === 0 ? -6 : 1 - dow; // back to Monday
      var calStart = new Date(firstDay);
      calStart.setDate(firstDay.getDate() + offset);

      var todayISO = fmtDate(new Date());
      var DAY_HEADERS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

      var html = '<table class="w-full border-collapse" style="min-width:480px">';

      // Header row
      html += '<thead><tr>';
      DAY_HEADERS.forEach(function (d) {
        var isMon = d === 'Mon';
        html += '<th class="pb-2 text-center text-xs font-semibold uppercase tracking-wide ' +
          (isMon ? 'text-purple-600' : 'text-gray-400') + '">' + d + '</th>';
      });
      html += '</tr></thead><tbody>';

      var cur = new Date(calStart);
      for (var week = 0; week < 6; week++) {
        html += '<tr>';
        for (var col = 0; col < 7; col++) {
          var curISO  = fmtDate(cur);
          var inMonth = cur.getMonth() === rsCurrentMonth.getMonth();
          var isToday = curISO === todayISO;
          var isMonday = col === 0;

          var entries = rsData.filter(function (e) { return e.date === curISO; });

          var cellClass = 'border border-gray-100 p-1.5 align-top ';
          if (isMonday && inMonth) cellClass += 'bg-purple-50/50 ';
          if (isToday) cellClass += 'ring-2 ring-inset ring-orange-400 ';

          var numClass = 'text-xs font-semibold mb-1 ';
          if (!inMonth)       numClass += 'text-gray-300';
          else if (isToday)   numClass += 'text-orange-500';
          else if (isMonday)  numClass += 'text-purple-600';
          else                numClass += 'text-gray-600';

          html += '<td class="' + cellClass + '" style="min-width:72px;height:72px">';
          html += '<div class="' + numClass + '">' + cur.getDate() + '</div>';

          entries.forEach(function (entry) {
            var wallStr   = entry.walls.join(', ') || '—';
            var setterStr = entry.setters.map(function (s) {
              return escHtml(s.name) + ' <span class="opacity-60">(' + s.routes + ')</span>';
            }).join(', ');
            var tooltipText = wallStr + '\n' +
              entry.setters.map(function (s) { return s.name + ': ' + s.routes + ' routes'; }).join(', ') +
              (entry.styles.length ? '\nStyles: ' + entry.styles.join(', ') : '') +
              (entry.notes ? '\nNotes: ' + entry.notes : '');
            var safeId = escHtml(String(entry.id));

            html += '<div class="mb-1 px-1.5 py-1 rounded bg-purple-100 border border-purple-200 ' +
              'text-xs text-purple-800 cursor-default group" title="' + escHtml(tooltipText) + '">' +
              '<div class="font-semibold truncate">' + escHtml(wallStr) + '</div>' +
              '<div class="text-purple-600 truncate leading-snug">' + setterStr + '</div>' +
              (entry.styles.length
                ? '<div class="text-purple-500 truncate opacity-75">' + escHtml(entry.styles.join(', ')) + '</div>'
                : '') +
              '<div class="flex gap-0.5 mt-0.5 opacity-0 group-hover:opacity-100 transition-opacity">' +
              '<button onclick="openRSEdit(\'' + safeId + '\')" type="button" title="Edit" ' +
              'class="p-0.5 rounded hover:bg-purple-300 transition">' +
              '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
              '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" ' +
              'd="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>' +
              '</svg></button>' +
              '<button onclick="deleteRSEntry(\'' + safeId + '\')" type="button" title="Delete" ' +
              'class="p-0.5 rounded hover:bg-purple-300 transition">' +
              '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
              '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" ' +
              'd="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>' +
              '</svg></button>' +
              '</div>' +
              '</div>';
          });

          html += '</td>';
          cur.setDate(cur.getDate() + 1);
        }
        html += '</tr>';
        // Stop after 5 rows if the whole month is already covered
        if (week >= 4 && cur.getMonth() !== rsCurrentMonth.getMonth()) break;
      }

      html += '</tbody></table>';
      document.getElementById('rs-calendar-body').innerHTML = html;
    }

    function rsNavMonth(dir) {
      if (!rsCurrentMonth) rsCurrentMonth = getMonthStart(new Date());
      rsCurrentMonth = new Date(rsCurrentMonth.getFullYear(), rsCurrentMonth.getMonth() + dir, 1);
      renderRSCalendar();
    }

    function rsGoToday() {
      rsCurrentMonth = getMonthStart(new Date());
      renderRSCalendar();
    }

    // ── Setter checkbox toggle ────────────────────────────────────────────────
    function toggleSetterInput(cb) {
      var input = document.querySelector('.rs-routes-input[data-setter="' + cb.value + '"]');
      if (!input) return;
      input.classList.toggle('hidden', !cb.checked);
      if (!cb.checked) input.value = '';
    }

    // ── Route setting form submit (create + update) ───────────────────────────
    document.getElementById('rs-form').addEventListener('submit', function (e) {
      e.preventDefault();
      var errEl = document.getElementById('rs-form-error');
      errEl.classList.add('hidden');

      var date = document.getElementById('rs-date').value;
      var walls = Array.from(document.querySelectorAll('.rs-wall-cb:checked'))
        .map(function (cb) { return cb.value; });
      var setters = Array.from(document.querySelectorAll('.rs-setter-cb:checked'))
        .map(function (cb) {
          var inp = document.querySelector('.rs-routes-input[data-setter="' + cb.value + '"]');
          return { name: cb.value, routes: parseInt((inp && inp.value) || '0', 10) || 0 };
        });
      var styles = Array.from(document.querySelectorAll('.rs-style-cb:checked'))
        .map(function (cb) { return cb.value; });
      var notes = document.getElementById('rs-notes').value.trim();

      if (!date)          { errEl.textContent = 'Please select a setting date.';        errEl.classList.remove('hidden'); return; }
      if (!walls.length)  { errEl.textContent = 'Please select at least one wall.';     errEl.classList.remove('hidden'); return; }
      if (!setters.length){ errEl.textContent = 'Please select at least one setter.';   errEl.classList.remove('hidden'); return; }

      var isEdit  = !!rsEditingId;
      var url     = isEdit ? '/api/routesetting/' + rsEditingId : '/api/routesetting';
      var method  = isEdit ? 'PATCH' : 'POST';

      var btn = document.getElementById('rs-submit-btn');
      btn.disabled = true; btn.textContent = 'Saving…';

      apiFetch(url, {
        method: method,
        body: JSON.stringify({
          date:    date,
          walls:   JSON.stringify(walls),
          setters: JSON.stringify(setters),
          styles:  JSON.stringify(styles),
          notes:   notes
        })
      })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          btn.disabled = false;
          btn.textContent = isEdit ? 'Update Session' : 'Save Session';
          if (data.error) { errEl.textContent = data.error; errEl.classList.remove('hidden'); return; }

          var parsed = parseRSEntry(data.entry);
          if (isEdit) {
            for (var i = 0; i < rsData.length; i++) {
              if (String(rsData[i].id) === String(rsEditingId)) { rsData[i] = parsed; break; }
            }
          } else {
            rsData.unshift(parsed);
          }
          rsCurrentMonth = getMonthStart(new Date(date + 'T00:00:00'));
          renderRSCalendar();
          resetRSForm();
          showToast(isEdit ? 'Session updated!' : 'Routesetting session saved!');
        })
        .catch(function (err) {
          btn.disabled = false;
          btn.textContent = isEdit ? 'Update Session' : 'Save Session';
          errEl.textContent = 'Save failed: ' + err.message;
          errEl.classList.remove('hidden');
        });
    });

    function resetRSForm() {
      rsEditingId = null;
      document.getElementById('rs-date').value = '';
      document.querySelectorAll('.rs-wall-cb, .rs-setter-cb, .rs-style-cb').forEach(function (cb) { cb.checked = false; });
      document.querySelectorAll('.rs-routes-input').forEach(function (inp) { inp.value = ''; inp.classList.add('hidden'); });
      document.getElementById('rs-notes').value = '';
      document.getElementById('rs-submit-btn').textContent = 'Save Session';
      document.getElementById('rs-cancel-btn').classList.add('hidden');
    }

    function cancelRSEdit() {
      resetRSForm();
    }

    function openRSEdit(id) {
      var entry = rsData.filter(function (e) { return String(e.id) === String(id); })[0];
      if (!entry) return;
      rsEditingId = id;

      document.getElementById('rs-date').value = entry.date;

      document.querySelectorAll('.rs-wall-cb').forEach(function (cb) {
        cb.checked = entry.walls.indexOf(cb.value) !== -1;
      });

      document.querySelectorAll('.rs-setter-cb').forEach(function (cb) {
        var sd = entry.setters.filter(function (s) { return s.name === cb.value; })[0];
        cb.checked = !!sd;
        var inp = document.querySelector('.rs-routes-input[data-setter="' + cb.value + '"]');
        if (inp) {
          if (sd) { inp.value = sd.routes; inp.classList.remove('hidden'); }
          else    { inp.value = '';        inp.classList.add('hidden'); }
        }
      });

      document.querySelectorAll('.rs-style-cb').forEach(function (cb) {
        cb.checked = entry.styles.indexOf(cb.value) !== -1;
      });

      document.getElementById('rs-notes').value = entry.notes;
      document.getElementById('rs-submit-btn').textContent = 'Update Session';
      document.getElementById('rs-cancel-btn').classList.remove('hidden');

      // Scroll the form into view
      document.getElementById('rs-form').scrollIntoView({ behavior: 'smooth', block: 'start' });
      showToast('Session loaded — edit and click Update Session.', '');
    }

    function deleteRSEntry(id) {
      if (!confirm('Delete this routesetting session?')) return;
      apiFetch('/api/routesetting/' + id, { method: 'DELETE' })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.error) { showToast('Delete failed: ' + data.error, 'error'); return; }
          rsData = rsData.filter(function (e) { return String(e.id) !== String(id); });
          renderRSCalendar();
          showToast('Session deleted.', 'warning');
        })
        .catch(function (err) { showToast('Delete failed: ' + err.message, 'error'); });
    }
  </script>
</MainLayout>
